:Paracoccus_denitrificans a :DenitrifyingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Paracoccus denitrificans" ;
    :OptimalPH "7.8"^^xsd:float ;
    :OptimalTemperature "32.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "40.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anoxic ;
    :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AnoxicOHOGrowthOnAcetate,
        :AnoxicOHOGrowthOnFSO,
        :AutotrophicDenitrification ;
    :reduces :Nitrate,
        :Nitrite ;
    rdfs:isDefinedBy "Paracoccus denitrificans is a model denitrifying bacterium performing complete reduction of nitrate through nitrite to dinitrogen under anoxic conditions and aerobic respiration when oxygen is present. In this ontology it is represented as a DenitrifyingBacteria with literature-sourced environmental growth conditions. Sources: Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Parameter a owl:DatatypeProperty ;
    rdfs:domain :Process ;
    rdfs:range xsd:float .

