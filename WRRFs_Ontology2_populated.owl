    :GujerNotation "K_I_HS_AS" ;
    :Unit "gS/m³" ;
    :Value "0.164"^^xsd:float ;
    rdfs:isDefinedBy "H₂S inhibition coefficient for acetoclastic sulfate-reducing microorganisms" .

:H2SInhibition_HS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "K_I_HS_HS" ;
    :Unit "gS/m³" ;
    :Value "0.55"^^xsd:float ;
    rdfs:isDefinedBy "H₂S inhibition coefficient for hydrogenotrophic sulfate-reducing microorganisms" .

