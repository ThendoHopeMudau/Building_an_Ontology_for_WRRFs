:hasParameter a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a process, microorganism, component, or system entity is associated with a quantitative or qualitative variable used to describe its behaviour, characteristics, or performance within a wastewater treatment system. Parameters may represent kinetic behaviour, stoichiometric relationships, environmental conditions, operational settings, or system properties used in process modelling, simulation, monitoring, and engineering analysis." ;
    rdfs:range :Parameters .

:ANO_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo" ;
    :GujerNotation "X_ANO" ;
    rdfs:isDefinedBy "A biomass component representing anaerobic heterotrophic microorganisms that degrade organic matter under anoxic or anaerobic conditions in wastewater treatment systems. ANO_Biomass contributes to processes such as denitrification, fermentation, and anaerobic carbon transformation through the utilisation of organic substrates in the absence of dissolved oxygen." .

:AcetogenicSRB a owl:Class ;
    rdfs:subClassOf :SulfateReducingBacteria .

:AmmoniaOxidizingBacteria a owl:Class ;
    rdfs:subClassOf :NitrifyingBacteria .

:DecayRate_ADO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_ADO" ;
    :Unit "1/d" ;
    :Value "0.15"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of autotrophic denitrifying microorganisms" .

:DecayRate_HM a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_HM" ;
    :Unit "1/d" ;
    :Value "0.01"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of hydrogenotrophic methanogenic microorganisms (X_HM) responsible for methane production using H₂ and CO₂" .

:DecayRate_OHO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_OHO" ;
    :Unit "1/d" ;
    :Value "0.62"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of ordinary heterotrophic microorganisms (X_OHO) during aerobic carbon oxidation and denitrification" .

:Eukarya a owl:Class ;
    rdfs:isDefinedBy "A domain of organisms whose cells contain a membrane-bound nucleus and specialised organelles. In wastewater treatment systems, eukaryotic microorganisms such as protozoa, fungi, and algae contribute to processes including organic matter degradation, biomass stabilisation, nutrient uptake, pathogen control, and sludge floc formation within biological treatment environments." ;
    rdfs:subClassOf :Microorganism .

:FilamentousBacteria a owl:Class ;
    rdfs:subClassOf :Bacteria .

:MaxGrowthRate_OHO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "mu_OHO_max" ;
    :Unit "1/d" ;
    :Value "6.0"^^xsd:float ;
    rdfs:isDefinedBy "Maximum specific growth rate for ordinary heterotrophic microorganisms" .

:NitriteOxidizingBacteria a owl:Class ;
    rdfs:subClassOf :NitrifyingBacteria .

:OperationalCondition a owl:DatatypeProperty ;
    rdfs:domain :Microorganism ;
    rdfs:isDefinedBy "A set of physical, chemical, biological, or environmental conditions under which a wastewater treatment process or reactor operates. Operational conditions include parameters such as temperature, pH, dissolved oxygen concentration, salinity, hydraulic retention time, sludge retention time, mixing intensity, and substrate loading, all of which influence microbial activity, process kinetics, treatment efficiency, and overall system performance." ;
    rdfs:range xsd:float .

:OrdinaryHetetrophicBacteria a owl:Class ;
    rdfs:subClassOf :HeterotrophicBacteria .

:PAO_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo" ;
    :GujerNotation "X_PAO" ;
    rdfs:isDefinedBy "A biomass component representing phosphate-accumulating organisms that are capable of taking up, storing, and cycling phosphorus within wastewater treatment systems. PAO_Biomass plays a central role in enhanced biological phosphorus removal processes by accumulating intracellular polyphosphate under alternating anaerobic and aerobic or anoxic conditions, thereby contributing to phosphorus removal, nutrient recovery, and wastewater treatment efficiency." .

:PH a owl:DatatypeProperty ;
    rdfs:domain :Microorganism ;
    rdfs:isDefinedBy "A measure of the acidity or alkalinity of a wastewater treatment environment, expressed as the concentration of hydrogen ions in solution. pH influences microbial activity, enzyme function, chemical equilibria, nutrient availability, reaction kinetics, and overall treatment performance, making it a critical operational parameter in wastewater treatment and resource recovery systems." ;
    rdfs:range xsd:float ;
    rdfs:subPropertyOf :OperationalCondition .

:SulfateReducingBacteria a owl:Class ;
    rdfs:subClassOf :SulfateRemovingBacteria .

:SulfurOxidizingbacteria a owl:Class ;
    rdfs:subClassOf :SulfateRemovingBacteria .

:Temperature a owl:DatatypeProperty ;
    rdfs:domain :Microorganism ;
    rdfs:isDefinedBy "A measure of the thermal condition of a wastewater treatment system or environment, typically expressed in degrees Celsius or Kelvin. Temperature influences microbial metabolism, enzyme activity, reaction kinetics, oxygen transfer, substrate utilisation, biomass growth, and overall treatment efficiency, making it a critical operational parameter in wastewater treatment and resource recovery processes." ;
    rdfs:range xsd:float ;
    rdfs:subPropertyOf :OperationalCondition .

:AC_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo",
        "X_ZAC" ;
    rdfs:isDefinedBy "A biomass component representing acetogenic microorganisms that convert fermentation products into acetate, hydrogen, and carbon dioxide under anaerobic conditions in wastewater treatment systems. Acetogenic biomass contributes to anaerobic digestion, carbon transformation, and the production of intermediates utilised in downstream processes such as methanogenesis and sulfate reduction." .

:AM_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo" ;
    :GujerNotation "X_ZAM" ;
    rdfs:isDefinedBy "A biomass component representing acetoclastic methanogenic microorganisms that convert acetate into methane and carbon dioxide under anaerobic conditions in wastewater treatment systems. AM_Biomass contributes to anaerobic digestion, carbon stabilisation, biogas production, and energy recovery processes within anaerobic treatment environments." .

:Bioreactor a owl:Class ;
    rdfs:isDefinedBy "A controlled treatment unit in which microorganisms perform biological reactions that transform, degrade, or remove contaminants from wastewater under defined environmental conditions such as aerobic, anoxic, or anaerobic conditions. Bioreactors provide the physical and chemical environment necessary for microbial growth, substrate utilisation, nutrient removal, and resource recovery processes in wastewater treatment systems." .

:DecayRate_AC a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_AC" ;
    :Unit "1/d" ;
    :Value "0.015"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of acetoclastic methanogenic microorganisms (X_AC) during anaerobic digestion and methane production from acetate" .

:DecayRate_AM a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_AM" ;
    :Unit "1/d" ;
    :Value "0.037"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of acetoclastic methanogenic microorganisms (X_AM) responsible for methane production from acetate under anaerobic conditions" .

:HydrogenotrophicMethanogen a owl:Class ;
    rdfs:subClassOf :Methanogen .

:HydrogenotrophicMethanogenesis a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :Hydrogen,
        :HydrogenIon,
        :Phosphate,
        :Sulphate ;
    :hasKineticParameter :DecayRate_HM,
        :HalfSatCoeff_HM,
        :MaxGrowthRate_HM ;
    :hasStoichiometricParameter :YieldCoeff_HM ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Methane,
        :Water ;
    :usesElectronAcceptor :Carbonate ;
    :usesElectronDonor :Hydrogen ;
    rdfs:isDefinedBy """Hydrogenotrophic methanogenesis is an anaerobic biological conversion process in which hydrogenotrophic methanogenic microorganisms use hydrogen (H₂) as an electron donor and carbon dioxide/carbonate species as electron acceptors to produce methane (CH₄), water, and methanogenic biomass.

This process is important in anaerobic digestion because it consumes hydrogen produced during fermentation and acetogenesis, helping to maintain low hydrogen partial pressure and supporting the thermodynamic feasibility of upstream anaerobic reactions. Hydrogenotrophic methanogenesis contributes to carbon transformation, methane production, biogas formation, and energy recovery in wastewater treatment systems.""" .

:MaxGrowthRate_AD a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "mu_AD" ;
    :Unit "1/d" ;
    :Value "0.8"^^xsd:float ;
    rdfs:isDefinedBy "Maximum specific growth rate for acidogenic microorganisms" .

:Methane a :Gas,
        owl:NamedIndividual ;
    :EmpiricalFormula "CH4" ;
    :GujerNotation "G_CH4" ;
    rdfs:isDefinedBy "A gaseous hydrocarbon component produced primarily during anaerobic biological processes in wastewater treatment systems. Methane is generated by methanogenic microorganisms during the conversion of acetate, hydrogen, and carbon dioxide in anaerobic digestion processes, contributing to carbon stabilisation, biogas production, renewable energy recovery, and greenhouse gas emissions within wastewater treatment and resource recovery systems." .

:NitrogenGas a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "N2" ;
    :GujerNotation "S_N2" ;
    rdfs:isDefinedBy "A gaseous nitrogen component produced during biological nitrogen removal processes in wastewater treatment systems. Nitrogen gas is primarily generated through denitrification and anaerobic ammonium oxidation processes, where oxidised nitrogen compounds such as nitrate and nitrite are converted into inert gaseous nitrogen, contributing to nitrogen removal, nutrient cycling, and effluent quality improvement within wastewater treatment systems." .

:OHO_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo",
        "X_OHO" ;
    rdfs:isDefinedBy "A biomass component representing ordinary heterotrophic organisms that utilise biodegradable organic matter as a carbon and energy source in wastewater treatment systems. OHO_Biomass contributes to processes such as aerobic organic matter degradation, denitrification, substrate conversion, and biomass growth, playing a major role in carbon removal and biological wastewater treatment performance." .

:OxygenNiche a owl:Class ;
    rdfs:isDefinedBy "The environmental condition or range of oxygen availability under which a microorganism or biological process can survive, grow, and function. Oxygen niches in wastewater treatment systems define whether microbial activity occurs under aerobic, anoxic, or anaerobic conditions, thereby influencing the distribution of microbial communities and the occurrence of processes such as nitrification, denitrification, fermentation, sulfate reduction, and methanogenesis." .

:Parameters a owl:Class ;
    rdfs:isDefinedBy "A parameter is a quantitative or qualitative variable used to describe, characterise, calibrate, or control wastewater treatment and resource recovery processes within a modelling or operational framework. Parameters may represent kinetic, stoichiometric, environmental, hydraulic, biochemical, or operational characteristics that influence microbial activity, substrate transformation, reaction rates, biomass growth, and overall process performance in wastewater treatment systems." .

:StorageOfPHAByXpa a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon,
        :Polyphosphate,
        :VolatileFattyAcids,
        :Water ;
    :isDefinedBy "Storage of polyhydroxyalkanoate by Xpa through uptake of volatile fatty acids and conversion into intracellular storage polymer under anaerobic conditions." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Calcium,
        :Carbonate,
        :HydrogenIon,
        :Magnesium,
        :Phosphate,
        :Polyhydroxyalkanoate,
        :Potassium ;
    :usesElectronDonor :VolatileFattyAcids .

:UptakeOfHydrogenInADM a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :Hydrogen,
        :HydrogenIon,
        :Phosphate ;
    :hasKineticParameter :DecayRate_HM,
        :MaxGrowthRate_HM ;
    :isDefinedBy "Anaerobic uptake and conversion of hydrogen by hydrogenotrophic methanogens resulting in methane production and methanogenic biomass growth during anaerobic digestion." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :HM_Biomass,
        :Methane,
        :Sulphate ;
    :usesElectronAcceptor :CarbonDioxide ;
    :usesElectronDonor :Hydrogen .

:XhmEndogenousDecay a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HM_Biomass,
        :HydrogenIon ;
    :hasKineticParameter :DecayRate_HM ;
    :isDefinedBy "Endogenous decay and lysis of hydrogenotrophic methanogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :UnbiodegradableParticulateOrganics .

:AnoxicBioreactor a :Bioreactor,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "A bioreactor operating under anoxic conditions in which dissolved oxygen is absent but alternative electron acceptors such as nitrate or nitrite are available for microbial metabolism in wastewater treatment systems. Anoxic bioreactors support processes such as denitrification and autotrophic denitrification, contributing to nitrogen removal, nutrient transformation, and biological wastewater treatment under oxygen-limited conditions." .

:DecayRate_AD a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_AD" ;
    :Unit "1/d" ;
    :Value "0.041"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of autotrophic denitrifying microorganisms (X_AD) during sulfur-based autotrophic denitrification" .

:FermentationOfFSO a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :FermentableBiodegradableSolubleOrganics,
        :HydrogenIon ;
    :hasKineticParameter :DecayRate_AD,
        :MaxGrowthRate_AD ;
    :isDefinedBy "Anaerobic fermentation of fermentable soluble organics resulting in the production of volatile fatty acids, hydrogen, and acidogenic biomass during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :Hydrogen,
        :Phosphate,
        :VolatileFattyAcids ;
    :usesElectronDonor :FermentableBiodegradableSolubleOrganics .

:Polyphosphate a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "KkpMgmpCacpPO3" ;
    :GujerNotation "X_PAO_PP" ;
    rdfs:isDefinedBy "A cellular phosphorus storage polymer accumulated by certain microorganisms in wastewater treatment systems, particularly phosphate-accumulating organisms. Polyphosphate functions as an intracellular phosphorus and energy reserve and plays a central role in enhanced biological phosphorus removal processes, where microorganisms alternately release and uptake phosphorus under anaerobic and aerobic or anoxic conditions, contributing to nutrient removal and phosphorus recovery." .

:Acetate a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "CH3COO-" ;
    :GujerNotation "S_VFA" ;
    rdfs:isDefinedBy "A soluble volatile fatty acid component commonly produced during the fermentation and acetogenesis of organic matter in wastewater treatment systems. Acetate serves as an important carbon source and electron donor for microorganisms involved in processes such as denitrification, sulfate reduction, and acetoclastic methanogenesis, thereby playing a central role in anaerobic digestion, carbon cycling, and biological nutrient removal." .

:AerobicGrowthOfXaut a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :DissolvedOxygen,
        :Magnesium,
        :Phosphate,
        :Sulphate ;
    :isDefinedBy "Aerobic growth of autotrophic nitrifying biomass using ammonium as the electron donor and dissolved oxygen as the electron acceptor, producing nitrate and autotrophic biomass during biological nitrogen removal." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :ANO_Biomass,
        :HydrogenIon,
        :Nitrate ;
    :usesElectronAcceptor :DissolvedOxygen ;
    :usesElectronDonor :Ammonium .

:AerobicOHOGrowthOnFSO a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :DissolvedOxygen,
        :FermentableBiodegradableSolubleOrganics,
        :Phosphate ;
    :hasKineticParameter :DecayRate_OHO,
        :MaxGrowthRate_OHO ;
    :isDefinedBy "Aerobic growth of ordinary heterotrophic organisms on fermentable soluble organics under aerobic conditions in wastewater treatment systems." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :HydrogenIon,
        :OHO_Biomass ;
    :usesElectronAcceptor :DissolvedOxygen ;
    :usesElectronDonor :FermentableBiodegradableSolubleOrganics .

:AutotrophicNitrification a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Carbonate,
        :Phosphate,
        :Sulphate ;
    :hasKineticParameter :DecayRate_ANO,
        :MaxGrowthRate_ANO ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :ANO_Biomass,
        :HydrogenIon,
        :Nitrate,
        :Water ;
    :usesElectronAcceptor :DissolvedOxygen ;
    :usesElectronDonor :Ammonium ;
    rdfs:isDefinedBy """Nitrification is an aerobic biological nitrogen removal process in which autotrophic nitrifying microorganisms (X_ANO) oxidize ammonium (NH4+) to nitrate (NO3−) using dissolved oxygen (O2) as the terminal electron acceptor. The process occurs within aerobic bioreactors and contributes to nitrogen conversion, alkalinity consumption, proton (H+) production, and biomass growth. 

During nitrification, ammonium serves as the electron donor while oxygen supports energy generation for autotrophic growth. The process produces nitrate, water, hydrogen ions, and autotrophic nitrifying biomass, and is governed by stoichiometric and kinetic parameters including growth rates, decay rates, half-saturation coefficients, and biomass yield coefficients. Nitrification plays a critical role in wastewater treatment systems by reducing ammonia toxicity, enabling downstream denitrification, and maintaining effluent nitrogen compliance.""" .

:Bacteria a owl:Class ;
    rdfs:isDefinedBy "A domain of single-celled prokaryotic microorganisms that play essential roles in biological wastewater treatment processes. Bacteria are responsible for the degradation and transformation of organic matter, nitrogen, phosphorus, sulfur compounds, and other contaminants through metabolic processes such as hydrolysis, fermentation, nitrification, denitrification, sulfate reduction, and enhanced biological phosphorus removal." ;
    rdfs:subClassOf :Microorganism .

:LysisOfOHOBiomass a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :OHO_Biomass ;
    :hasKineticParameter :DecayRate_OHO_AD ;
    :isDefinedBy "Lysis of ordinary heterotrophic organism biomass into biodegradable particulate organics and endogenous residue during biomass decay." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :Sulphate,
        :UnbiodegradableParticulateOrganics,
        :Water .

:LysisOfXaut a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :ANO_Biomass ;
    :isDefinedBy "Lysis of autotrophic nitrifying biomass into biodegradable particulate organics, endogenous residue, and inorganic nutrient products during biomass decay in wastewater treatment systems." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :UnbiodegradableParticulateOrganics .

:Potassium a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "K+" ;
    :GujerNotation "S_K" ;
    rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and saline wastewaters. Potassium serves as an essential nutrient for microbial growth and cellular function and participates in osmotic regulation, ionic balance, biological phosphorus removal, mineral precipitation, and nutrient recovery processes within wastewater treatment and resource recovery systems." .

:Propionate a :Soluble,
        owl:NamedIndividual ;
    :GujerNotation "CH3CH2COO-",
        "S_Pr" ;
    rdfs:isDefinedBy "A soluble volatile fatty acid component produced during the fermentation and degradation of organic matter in wastewater treatment systems. Propionate serves as an intermediate substrate in anaerobic digestion and carbon transformation processes and is utilised by microorganisms during acetogenesis, sulfate reduction, and methanogenesis, thereby contributing to microbial metabolism, biogas production, and nutrient cycling within wastewater treatment systems." .

:AnoxicOHOGrowthOnAcetate a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Acetate,
        :Ammonium,
        :Carbonate,
        :Nitrate,
        :Phosphate ;
    :hasKineticParameter :DecayRate_OHO,
        :MaxGrowthRate_OHO ;
    :isDefinedBy "Anoxic growth of ordinary heterotrophic organisms on acetate coupled with nitrate reduction during biological nitrogen removal processes in wastewater treatment systems." ;
    :occursIn :AnoxicBioreactor ;
    :producesProduct :HydrogenIon,
        :NitrogenGas,
        :OHO_Biomass ;
    :usesElectronAcceptor :Nitrate ;
    :usesElectronDonor :Acetate .

:AnoxicOHOGrowthOnFSO a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :FermentableBiodegradableSolubleOrganics,
        :Nitrate,
        :Phosphate ;
    :hasKineticParameter :DecayRate_OHO,
        :MaxGrowthRate_OHO ;
    :isDefinedBy "Anoxic growth of ordinary heterotrophic organisms on fermentable soluble organics coupled with nitrate reduction during biological nitrogen removal processes in wastewater treatment systems." ;
    :occursIn :AnoxicBioreactor ;
    :producesProduct :HydrogenIon,
        :NitrogenGas,
        :OHO_Biomass ;
    :usesElectronAcceptor :Nitrate ;
    :usesElectronDonor :FermentableBiodegradableSolubleOrganics .

:Calcium a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "Ca2+" ;
    :GujerNotation "S_Ca" ;
    rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and natural waters. Calcium participates in chemical precipitation, mineral formation, alkalinity balance, floc formation, and phosphorus removal processes, and contributes to the formation of compounds such as calcite and calcium phosphate under specific environmental and operational conditions." .

:HydrogenSulfide a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "HS-" ;
    :GujerNotation "S_HS" ;
    rdfs:isDefinedBy "A dissolved reduced sulfur component produced during sulfate reduction and anaerobic degradation processes in wastewater treatment systems. Hydrogen sulfide acts as an electron donor in sulfur oxidation and autotrophic denitrification processes, while also contributing to odor generation, toxicity, corrosion, gas emissions, and sulfur cycling within wastewater treatment and resource recovery systems." .

:Nitrite a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "NO2-" ;
    :GujerNotation "S_NO2" ;
    rdfs:isDefinedBy "Nitrite is a soluble inorganic nitrogen component that occurs as an intermediate in nitrification and denitrification. In wastewater treatment systems, nitrite can serve as an electron acceptor during anoxic microbial metabolism and is important in biological nitrogen removal." .

:SulfurRemovalProcess a owl:Class ;
    rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, oxidation, reduction, or removal of sulfur-containing compounds from wastewater. Sulfur removal processes regulate compounds such as sulfate and sulfide through biological, chemical, or physical mechanisms, contributing to odor control, corrosion prevention, toxicity reduction, nutrient cycling, and the recovery or stabilisation of sulfur compounds within wastewater treatment systems." ;
    rdfs:subClassOf :Process .

:AnoxicGrowthOfAutotrophicDenitrifiers a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :HydrogenSulfide,
        :Nitrate,
        :Phosphate ;
    :hasKineticParameter :DecayRate_ADO,
        :MaxGrowthRate_ADO ;
    :isDefinedBy "Anoxic growth of autotrophic denitrifying microorganisms using hydrogen sulfide as the electron donor and nitrate as the electron acceptor, resulting in sulfate production, nitrogen removal, and autotrophic biomass growth in wastewater treatment systems." ;
    :occursIn :AnoxicBioreactor ;
    :producesProduct :ADO_Biomass,
        :HydrogenIon,
        :NitrogenGas,
        :Sulphate ;
    :usesElectronAcceptor :Nitrate ;
    :usesElectronDonor :HydrogenSulfide .

:AutotrophicDenitrification a :NitrogenRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Carbonate,
        :HydrogenIon,
        :Phosphate ;
    :hasKineticParameter :DecayRate_ADO,
        :MaxGrowthRate_ADO ;
    :hasStoichiometricParameter :YieldCoeff_ADO ;
    :occursIn :AnoxicBioreactor ;
    :producesProduct :NitrogenGas,
        :Sulphate,
        :Water ;
    :usesElectronAcceptor :Nitrate ;
    :usesElectronDonor :HydrogenSulfide ;
    rdfs:isDefinedBy """Autotrophic denitrification is an anoxic biological nitrogen removal process in which autotrophic denitrifying microorganisms (X_ADO) reduce nitrate (NO3−) and/or nitrite (NO2−) to nitrogen gas (N₂) using inorganic reduced sulfur compounds, such as sulfide (H₂S), elemental sulfur (S⁰), or thiosulfate (S₂O₃²−), as electron donors. The process occurs under anoxic conditions where dissolved oxygen is absent and nitrate or nitrite serves as the terminal electron acceptor. 

During autotrophic denitrification, inorganic carbon sources such as carbonate or bicarbonate are utilized for autotrophic biomass growth. The process contributes to simultaneous nitrogen removal and sulfur oxidation within wastewater treatment systems, producing sulfate (SO₄²−), nitrogen gas, water, protons, and autotrophic denitrifying biomass. Autotrophic denitrification is particularly important in saline and sulfur-rich wastewater treatment systems, including SANI-based processes, due to its lower organic carbon requirement and reduced sludge production compared to heterotrophic denitrification. The process is governed by stoichiometric and kinetic parameters including growth rates, decay rates, half-saturation coefficients, inhibition coefficients, and biomass yield coefficients.""" .

:DenitrifyingBacteria a owl:Class ;
    rdfs:subClassOf :Bacteria .

:FermentableBiodegradableSolubleOrganics a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYfOZfNAfPBf" ;
    :GujerNotation "S_F" ;
    rdfs:isDefinedBy "A soluble biodegradable organic component consisting of readily fermentable dissolved organic matter present in wastewater treatment systems. Fermentable biodegradable soluble organics serve as substrates for fermentative microorganisms, supporting the production of volatile fatty acids, alcohols, hydrogen, and other intermediate compounds during anaerobic and anoxic biological processes such as fermentation, acetogenesis, sulfate reduction, and methanogenesis." .

:MicroorganismBiomass a owl:Class ;
    rdfs:isDefinedBy "A biological component representing living or active microbial matter within a wastewater treatment system. Biomass components consist of microorganisms and associated cellular material that drive biological treatment processes such as organic matter degradation, nutrient removal, sulfate reduction, fermentation, and methanogenesis through their metabolic activity and growth." ;
    rdfs:subClassOf :Component .

:NitrogenRemovalProcess a owl:Class ;
    rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, conversion, or removal of nitrogen-containing compounds from wastewater. Nitrogen removal processes reduce concentrations of compounds such as ammonium, nitrite, and nitrate through biological, chemical, or physical mechanisms, thereby preventing eutrophication, protecting aquatic ecosystems, and improving effluent quality in wastewater treatment systems." ;
    rdfs:subClassOf :Process ;
    owl:disjointWith :PhosphorusRemovalProcess,
        :SulfurRemovalProcess .

:Polyhydroxyalkanoate a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "C4H6O2" ;
    :GujerNotation "X_PAO_Stor" ;
    rdfs:isDefinedBy "A cellular storage polymer produced and accumulated by certain microorganisms in wastewater treatment systems as an internal carbon and energy reserve. Polyhydroxyalkanoate plays an important role in microbial metabolism and enhanced biological phosphorus removal processes, particularly in phosphate-accumulating organisms, where it is synthesised under anaerobic conditions and later utilised for growth, phosphorus uptake, and energy generation under aerobic or anoxic conditions." .

:DissolvedOxygen a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "O2" ;
    :GujerNotation "S_O2" ;
    rdfs:isDefinedBy "A dissolved gaseous oxygen component present in the liquid phase of wastewater treatment systems. Dissolved oxygen serves as the primary terminal electron acceptor for aerobic microorganisms and is essential for biological processes such as aerobic organic matter degradation, nitrification, and aerobic phosphorus removal. Dissolved oxygen concentration strongly influences microbial activity, reaction kinetics, treatment efficiency, and the operational performance of aerobic treatment processes." .

:Magnesium a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "Mg2+" ;
    :GujerNotation "S_Mg" ;
    rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and natural waters. Magnesium participates in biological and chemical processes including mineral precipitation, struvite formation, phosphorus recovery, alkalinity balance, floc formation, and nutrient removal, and plays an important role in wastewater treatment, sludge processing, and resource recovery systems." .

:AerobicBioreactor a :Bioreactor,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "A bioreactor operating under aerobic conditions in which dissolved oxygen is supplied to support the growth and metabolic activity of aerobic microorganisms in wastewater treatment systems. Aerobic bioreactors facilitate processes such as organic matter degradation, nitrification, and biological phosphorus removal through oxygen-dependent biological reactions and microbial transformations." .

:Anoxic a :OxygenNiche,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "An environmental condition characterised by the absence of dissolved oxygen but the presence of alternative electron acceptors such as nitrate or nitrite in wastewater treatment systems. Anoxic conditions support biological processes such as denitrification and autotrophic denitrification, where microorganisms utilise oxidised nitrogen compounds instead of oxygen for energy generation and nutrient removal." .

:UnbiodegradableParticulateOrganics a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "X_U_inf" ;
    :GujerNotation "CHYupOZupNAupPBup" ;
    rdfs:isDefinedBy "A particulate organic component consisting of suspended organic matter that cannot be readily degraded or biologically transformed by microorganisms within wastewater treatment systems. Unbiodegradable particulate organics contribute to inert solids accumulation, sludge production, suspended solids concentration, and solids handling processes, and may persist throughout biological treatment and sludge processing operations." .

:Component a owl:Class ;
    rdfs:isDefinedBy "A chemical, biological, or physical entity represented within a wastewater treatment system or process model. Components may include dissolved substrates, particulate matter, microbial biomass, nutrients, gases, ions, and storage compounds that participate in biological, chemical, or physical transformations during wastewater treatment." .

:Glucose a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "C6H12O6" ;
    :GujerNotation "S_Glu" ;
    rdfs:isDefinedBy "A soluble biodegradable organic component commonly present in wastewater and utilised as a carbon and energy source by microorganisms during biological treatment processes. Glucose supports microbial growth and metabolism in processes such as aerobic respiration, fermentation, denitrification, sulfate reduction, and anaerobic digestion, contributing to organic matter degradation, biomass production, and carbon transformation within wastewater treatment systems." .

:Particulate a owl:Class ;
    rdfs:isDefinedBy "A component consisting of suspended or insoluble solid material present within a wastewater treatment system. Particulate components may include organic matter, microbial biomass, inert solids, precipitates, and particulate substrates that participate in sedimentation, hydrolysis, biological conversion, sludge formation, and solids handling processes during wastewater treatment." ;
    rdfs:subClassOf :Component .

:EndogenousResidue a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHyeOzeNaePbe" ;
    :GujerNotation "X_U_Org" ;
    rdfs:isDefinedBy "A particulate organic component representing biodegradable microbial residues and cellular materials released through endogenous decay, biomass lysis, and microbial metabolism in wastewater treatment systems. Endogenous residues contribute to sludge composition, particulate organic matter accumulation, substrate recycling, and subsequent degradation or stabilisation processes during biological wastewater treatment and sludge digestion." .

:Hydrogen a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "H2" ;
    :GujerNotation "S_H2" ;
    rdfs:isDefinedBy "A dissolved gaseous component that serves as an important electron donor and intermediate compound in anaerobic wastewater treatment systems. Hydrogen is produced during fermentation and acetogenesis and is utilised by microorganisms in processes such as hydrogenotrophic methanogenesis, sulfate reduction, and autotrophic denitrification, thereby contributing to carbon transformation, energy transfer, biogas production, and microbial metabolic interactions within wastewater treatment processes." .

:StoichiometricParameter a owl:Class,
        owl:DatatypeProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A parameter that defines the quantitative relationship between reactants, products, biomass, and other components involved in a biological, chemical, or physical process within a wastewater treatment system. Stoichiometric parameters are used to represent mass and elemental conversion relationships, supporting mass balance analysis, process modelling, reaction formulation, and the construction of stoichiometric matrices such as the Gujer matrix." ;
    rdfs:range xsd:float ;
    rdfs:subClassOf :Parameters .

:Water a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "H2O" ;
    :GujerNotation "H2O" ;
    rdfs:isDefinedBy "A soluble organic component consisting of volatile fatty acids produced during the fermentation and anaerobic degradation of organic matter in wastewater treatment systems. VFAs serve as important intermediate substrates and carbon sources for microorganisms involved in processes such as denitrification, sulfate reduction, enhanced biological phosphorus removal, acetogenesis, and methanogenesis, thereby contributing to carbon transformation, nutrient removal, and anaerobic digestion processes." .

:BiodegradableParticulateOrganics a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYbpOzbpNAbpPBbp" ;
    :GujerNotation "X_B_Org" ;
    rdfs:isDefinedBy "A particulate organic component consisting of biodegradable suspended organic matter present in wastewater treatment systems. Biodegradable particulate organics serve as a substrate for microbial degradation processes such as hydrolysis, fermentation, aerobic oxidation, and anaerobic digestion, contributing to carbon removal, biomass growth, nutrient transformation, and energy recovery within wastewater treatment processes." .

:VolatileFattyAcids a :Soluble,
        owl:NamedIndividual ;
    :GujerNotation "S_VFA" ;
    rdfs:isDefinedBy "A soluble organic component consisting of volatile fatty acids produced during the fermentation and anaerobic degradation of organic matter in wastewater treatment systems. VFAs serve as important intermediate substrates and carbon sources for microorganisms involved in processes such as denitrification, sulfate reduction, enhanced biological phosphorus removal, acetogenesis, and methanogenesis, thereby contributing to carbon transformation, nutrient removal, and anaerobic digestion processes." .

:PhosphorusRemovalProcess a owl:Class ;
    rdfs:isDefinedBy "A wastewater treatment process involved in the uptake, transformation, storage, or removal of phosphorus-containing compounds from wastewater. Phosphorus removal processes reduce phosphate concentrations through biological, chemical, or physical mechanisms, thereby preventing eutrophication, improving effluent quality, and supporting nutrient management and resource recovery within wastewater treatment systems." ;
    rdfs:subClassOf :Process ;
    owl:disjointWith :SulfurRemovalProcess .

:Process a owl:Class ;
    rdfs:isDefinedBy "A biological, chemical, or physical transformation or activity that occurs within a wastewater treatment system, resulting in the conversion, degradation, removal, or recovery of substances. Processes are driven by interactions between microorganisms, substrates, environmental conditions, and operational parameters, and collectively determine the performance and efficiency of wastewater treatment and resource recovery systems." .

:Anaerobic a :OxygenNiche,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "An environmental condition characterised by the absence of dissolved oxygen and alternative oxidised electron acceptors such as nitrate and nitrite in wastewater treatment systems. Anaerobic conditions support processes such as fermentation, acetogenesis, sulfate reduction, and methanogenesis through the activity of anaerobic microorganisms involved in organic matter degradation, nutrient transformation, and biogas production." ;
    owl:differentFrom :Anoxic .

:Nitrate a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "NO3-" ;
    :GujerNotation "S_NOx" ;
    rdfs:isDefinedBy "A dissolved inorganic nitrogen component present in wastewater treatment systems and commonly formed during nitrification processes. Nitrate serves as an alternative terminal electron acceptor for microorganisms under anoxic conditions and plays a central role in biological nitrogen removal processes such as denitrification and autotrophic denitrification, contributing to nutrient transformation, nitrogen cycling, and effluent quality improvement within wastewater treatment systems." .

:Aerobic a :OxygenNiche,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "An environmental condition characterised by the presence of dissolved oxygen as the primary terminal electron acceptor for biological and chemical processes in wastewater treatment systems. Aerobic conditions support processes such as organic matter degradation, nitrification, and aerobic phosphorus removal by promoting the activity of oxygen-dependent microorganisms." ;
    owl:differentFrom :Anaerobic,
        :Anoxic .

:Microorganism a owl:Class ;
    rdfs:isDefinedBy "A living microbial organism or functional microbial group involved in biological transformations within wastewater treatment systems. Microorganisms drive essential treatment processes such as organic matter degradation, nitrification, denitrification, phosphorus removal, sulfate reduction, fermentation, and methanogenesis through their metabolic activities and interactions with environmental conditions and substrates." .

:CarbonRemovalProcess a owl:Class ;
    rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, degradation, or removal of carbon-containing compounds from wastewater. Carbon removal processes primarily reduce biodegradable and non-biodegradable organic matter through biological, chemical, or physical mechanisms, contributing to improved effluent quality, reduced oxygen demand, and stabilisation of organic pollutants within treatment systems." ;
    rdfs:subClassOf :Process ;
    owl:disjointWith :NitrogenRemovalProcess,
        :PhosphorusRemovalProcess,
        :SulfurRemovalProcess .

:Soluble a owl:Class ;
    rdfs:isDefinedBy "A component that is dissolved within the liquid phase of a wastewater treatment system and is not present as suspended solids. Soluble components include dissolved substrates, nutrients, ions, gases, and metabolic products that are readily available for transport, microbial uptake, chemical reactions, and biological transformation processes during wastewater treatment." ;
    rdfs:subClassOf :Component .

:Sulphate a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "SO42-" ;
    :GujerNotation "S_SO4" ;
    rdfs:isDefinedBy "A dissolved inorganic sulfur component commonly present in wastewater treatment systems and saline wastewaters. Sulphate serves as an alternative electron acceptor for sulfate-reducing microorganisms under anaerobic conditions and plays an important role in sulfur cycling, sulfide production, autotrophic denitrification, salinity effects, corrosion processes, odor generation, and nutrient transformations within wastewater treatment and resource recovery systems." .

:AnaerobicBioreactor a :Bioreactor,
        owl:NamedIndividual ;
    rdfs:isDefinedBy "A bioreactor operating under anaerobic conditions in which dissolved oxygen and alternative oxidised electron acceptors are absent, allowing anaerobic microorganisms to carry out biological processes such as fermentation, acetogenesis, sulfate reduction, and methanogenesis in wastewater treatment systems. Anaerobic bioreactors support organic matter stabilisation, nutrient transformation, sludge reduction, biogas production, and energy recovery through anaerobic microbial activity." .

:Ammonium a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "NH4+" ;
    :GujerNotation "S_NHx" ;
    rdfs:isDefinedBy "A soluble inorganic nitrogen component present in wastewater treatment systems, typically in the form of ammonia or ammonium ions. Ammonium serves as a key nitrogen substrate for biological processes such as nitrification, assimilation, and anaerobic ammonium oxidation, and plays an important role in nutrient cycling, microbial metabolism, and nitrogen removal within wastewater treatment processes." .

:KineticParameter a owl:Class,
        owl:DatatypeProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A parameter that describes the rate, or dynamic behaviour of a biological, chemical, or physical process within a wastewater treatment system. Kinetic parameters quantify how microorganisms and processes respond to substrates, environmental conditions, and operational factors, and are essential for process modelling, simulation, calibration, optimisation, and the prediction of treatment system performance." ;
    rdfs:range xsd:float ;
    rdfs:subClassOf :Parameters .

:Phosphate a :Soluble,
        owl:NamedIndividual ;
    :GujerNotation "PO43-",
        "S_PO4" ;
    rdfs:isDefinedBy "A dissolved inorganic phosphorus component present in wastewater treatment systems, primarily in the form of phosphate ions. Phosphate serves as an essential nutrient for microbial growth and metabolism and plays a central role in biological and chemical phosphorus removal, nutrient cycling, mineral precipitation, eutrophication control, and resource recovery processes within wastewater treatment systems." .

:HydrogenIon a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "H+" ;
    :GujerNotation "S_H" ;
    rdfs:isDefinedBy "A dissolved chemical component representing hydrogen ions in aqueous solution within wastewater treatment systems. Hydrogen ions determine the acidity or alkalinity of the treatment environment and play a critical role in pH regulation, chemical equilibria, microbial activity, reaction kinetics, nutrient availability, and overall process stability during biological and physicochemical wastewater treatment processes." .

:Carbonate a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "CO32-" ;
    :GujerNotation "S_CO3" ;
    rdfs:isDefinedBy "A dissolved inorganic carbon component present in wastewater treatment systems, primarily in the form of carbonate and bicarbonate ions. Carbonate contributes to alkalinity, pH buffering, inorganic carbon availability, mineral precipitation, and chemical equilibrium processes, and plays an important role in biological treatment, nitrification, anaerobic digestion, and carbonate mineral formation within wastewater treatment and resource recovery systems." .

