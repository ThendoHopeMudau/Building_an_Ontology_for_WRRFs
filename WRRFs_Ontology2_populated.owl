    :GujerNotation "mu_AM" ;
    :Unit "1/d" ;
    :Value "4.39"^^xsd:float ;
    rdfs:isDefinedBy "Maximum specific growth rate for acetoclastic methanogenic microorganisms" .

:MaxGrowthRate_HM a :KineticParameter,
