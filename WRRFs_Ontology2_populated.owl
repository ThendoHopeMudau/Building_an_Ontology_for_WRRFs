    :GujerNotation "KS_ACS" ;
    :Unit "gN/m³" ;
    :Value "0.07703"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for nitrogen uptake by acetogenic sulfate-reducing microorganisms" .

:HalfSatCoeff_N_AS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_AS" ;
    :Unit "gN/m³" ;
    :Value "0.1999"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for nitrogen uptake by acetoclastic sulfate-reducing microorganisms" .

