        :AnoxicOHOGrowthOnFSO,
        :AutotrophicDenitrification ;
    :reduces :Nitrate,
        :Nitrite ;
    rdfs:isDefinedBy "Stutzerimonas stutzeri is a widespread denitrifying bacterium (formerly Pseudomonas stutzeri) reducing nitrate and nitrite to dinitrogen, relevant to biological nitrogen removal. In this ontology it is represented as a DenitrifyingBacteria with literature-sourced environmental growth conditions. Sources: Lalucat J et al. (2006) Biology of Pseudomonas stutzeri. Microbiol Mol Biol Rev 70(2):510-547." .

:Syntrophomonas_wolfei a :AcidogenicBacteria,
        owl:NamedIndividual ;
    rdfs:label "Syntrophomonas wolfei" ;
    :OptimalPH "7.2"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
