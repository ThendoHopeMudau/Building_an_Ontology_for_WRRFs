        :Phosphate,
        :UnbiodegradableParticulateOrganics .

:LysisOfXpa a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon,
        :PAO_Biomass ;
    :isDefinedBy "Lysis of Xpa biomass into biodegradable particulate organics, endogenous residue, and inorganic nutrient components during biomass decay." ;
    :occursIn :AerobicBioreactor,
        :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :UnbiodegradableParticulateOrganics .

