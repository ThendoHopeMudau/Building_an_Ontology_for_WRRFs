@prefix : <http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2> a owl:Ontology ;
    rdfs:comment "A knowledge model for wastewater treatment systems that models microorganisms, their traits, functional roles, metabolic processes, operational indicators, and interactions with environmental conditions to support modelling, monitoring, and resource recovery applications." .

:Acetivibrio_clariflavus a :AcetoclasticSRB,
        :DenitrifyingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Acetivibrio clariflavus" ;
    :BacDiveID 2853 ;
    :OptimalPH "7.5"^^xsd:float ;
    :OptimalTemperature "57.5"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :SalinityMax "0.7"^^xsd:float ;
    :SalinityMin "0.0"^^xsd:float ;
    :TemperatureMax "65.0"^^xsd:float ;
    :TemperatureMin "45.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic,
        :Anoxic ;
    :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AutotrophicDenitrification,
        :GrowthOfAcetoclasticSRB,
        :LysisOfADO ;
    :reduces :Nitrate,
        :Sulphate ;
    rdfs:isDefinedBy "Acetivibrio clariflavus is an anaerobic thermophilic microorganism capable of reducing sulfate and nitrate under oxygen-limited conditions. In this ontology, it is represented as a microorganism with defined environmental growth conditions and sulfur- and nitrogen-reduction capabilities relevant to wastewater microbial processes." .

:Acetivibrio_saccincola a :AcetoclasticSRB,
        owl:NamedIndividual ;
    rdfs:label "Acetivibrio saccincola" ;
    :BacDiveID 132679 ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "60.0"^^xsd:float ;
    :PHMax "9.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :SalinityMax "0.2"^^xsd:float ;
    :SalinityMin "0.0"^^xsd:float ;
    :TemperatureMax "65.0"^^xsd:float ;
    :TemperatureMin "45.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :reduces :Sulphate ;
    rdfs:isDefinedBy "Acetivibrio saccincola is an anaerobic thermophilic microorganism associated with sulfate reduction under saline and oxygen-limited conditions. In this ontology, it is represented as a microorganism with environmental growth constraints and sulfur reduction capability." .

:Acetogenesis a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Phosphate,
        :Propionate,
        :Sulphate,
        :Water ;
    :hasKineticParameter :DecayRate_AC,
        :HalfSatCoeff_AC,
        :MaxGrowthRate_AC ;
    :hasStoichiometricParameter :YieldCoeff_AC ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :AC_Biomass,
        :Carbonate,
        :Hydrogen,
        :HydrogenIon,
        :VolatileFattyAcids ;
    :usesElectronAcceptor :HydrogenIon ;
    :usesElectronDonor :Propionate ;
    rdfs:isDefinedBy """Acetogenesis is an anaerobic biological conversion process in which acetogenic microorganisms transform intermediate fermentation products, particularly propionate and other soluble organic compounds, into acetate, hydrogen (H₂), and carbon dioxide/carbonate species. The process occurs under anaerobic conditions and represents a critical intermediate stage linking acidogenesis and methanogenesis during anaerobic digestion.

Acetogenic microorganisms use propionate and related organic substrates as electron donors while maintaining metabolic activity under low hydrogen partial pressure conditions to ensure thermodynamic feasibility. The products generated during acetogenesis serve as essential substrates for acetoclastic and hydrogenotrophic methanogenic microorganisms responsible for methane production. The process contributes to organic matter degradation, carbon transformation, and energy recovery within wastewater treatment systems and is governed by stoichiometric and kinetic parameters including maximum growth rate, decay rate, half-saturation coefficients, and biomass yield coefficients.""" .

:Acinetobacter_johnsonii a :OrdinaryHetetrophicBacteria,
        owl:NamedIndividual ;
    rdfs:label "Acinetobacter johnsonii" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "30.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "37.0"^^xsd:float ;
    :TemperatureMin "10.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :AnoxicOHOGrowthOnAcetate,
        :AnoxicOHOGrowthOnFSO,
        :FermentationOfFSO,
        :LysisOfOHOBiomass ;
    rdfs:isDefinedBy "Acinetobacter johnsonii is an ordinary heterotrophic bacterium of activated sludge historically associated with phosphate uptake studies, oxidising organic substrates aerobically. In this ontology it is represented as a OrdinaryHetetrophicBacteria with literature-sourced environmental growth conditions. Sources: Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Algae a owl:Class ;
    rdfs:subClassOf :Eukarya .

:Anaeromicrobium_sediminis a :DenitrifyingBacteria,
        :HydrogenotrophicSRB,
        owl:NamedIndividual ;
    rdfs:label "Anaeromicrobium sediminis" ;
    :BacDiveID 140570 ;
    :OptimalPH "7.5"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
    :PHMax "9.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :SalinityMax "30.0"^^xsd:float ;
    :SalinityMin "10.0"^^xsd:float ;
    :TemperatureMax "40.0"^^xsd:float ;
    :TemperatureMin "25.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic,
        :Anoxic ;
    :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AutotrophicDenitrification,
        :DeathAndDecayOfHydrogenotrophicSRB,
        :GrowthOfHydrogenotrophicSRB,
        :LysisOfADO ;
    :reduces :ElementalSulfur,
        :Nitrate,
        :Sulfite,
        :Sulphate,
        :Thiosulfate ;
    rdfs:isDefinedBy "Anaeromicrobium sediminis is an anaerobic microorganism capable of reducing sulfate, elemental sulfur, sulfite, thiosulfate, and nitrate. In this ontology, it is represented as a sulfur- and nitrogen-transforming microorganism associated with saline anaerobic environments and wastewater sulfur cycling." .

:Anaerosacchariphilus_polymeriproducens a :AcetogenicSRB,
