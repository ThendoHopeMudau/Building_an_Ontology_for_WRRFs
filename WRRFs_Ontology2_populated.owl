    :GujerNotation "KS_HM" ;
    :Unit "g/m³" ;
    :Value "0.156"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for hydrogenotrophic methanogenic microorganisms" .

:HalfSatCoeff_HS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_HS" ;
    :Unit "g/m³" ;
    :Value "0.004375"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for hydrogenotrophic sulfate-reducing microorganisms" .

:HalfSatCoeff_N_ACS a :KineticParameter,
