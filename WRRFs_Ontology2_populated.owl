    :consumesSubstrate :HydrogenIon,
        :Newberyite ;
    :isDefinedBy "Dissolution of newberyite resulting in the release of magnesium and phosphate into solution during phosphorus transformation and mineral dissolution processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Magnesium,
        :Phosphate .

:Nitrobacter_winogradskyi a :NitriteOxidizingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Nitrobacter winogradskyi" ;
    :OptimalPH "7.9"^^xsd:float ;
    :OptimalTemperature "38.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "42.0"^^xsd:float ;
    :TemperatureMin "5.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicGrowthOfXaut,
        :AutotrophicNitrification,
        :LysisOfXaut ;
    rdfs:isDefinedBy "Nitrobacter winogradskyi is a chemolithoautotrophic nitrite-oxidizing bacterium that oxidises nitrite to nitrate, active as an r-strategist NOB at higher nitrite concentrations in nitrifying sludge. In this ontology it is represented as a NitriteOxidizingBacteria with literature-sourced environmental growth conditions. Sources: Grunditz C, Dalhammar G (2001) Development of nitrification inhibition assays using pure cultures of Nitrosomonas and Nitrobacter. Water Research 35(2):433-440.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Nitrosomonas_europaea a :AmmoniaOxidizingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Nitrosomonas europaea" ;
    :OptimalPH "8.0"^^xsd:float ;
    :OptimalTemperature "35.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "42.0"^^xsd:float ;
    :TemperatureMin "5.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicGrowthOfXaut,
        :AutotrophicNitrification,
        :LysisOfXaut ;
    rdfs:isDefinedBy "Nitrosomonas europaea is a chemolithoautotrophic ammonia-oxidizing bacterium and one of the principal AOB in nitrifying activated sludge, oxidising ammonia to nitrite under aerobic conditions. In this ontology it is represented as a AmmoniaOxidizingBacteria with literature-sourced environmental growth conditions. Sources: Grunditz C, Dalhammar G (2001) Development of nitrification inhibition assays using pure cultures of Nitrosomonas and Nitrobacter. Water Research 35(2):433-440.; Koops H-P, Pommerening-Roser A (2001) Distribution and ecophysiology of the nitrifying bacteria emphasizing cultured species. FEMS Microbiology Ecology 37:1-9." .

:Nitrosomonas_eutropha a :AmmoniaOxidizingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Nitrosomonas eutropha" ;
    :OptimalPH "7.8"^^xsd:float ;
    :OptimalTemperature "30.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "42.0"^^xsd:float ;
    :TemperatureMin "5.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicGrowthOfXaut,
        :AutotrophicNitrification,
        :LysisOfXaut ;
    rdfs:isDefinedBy "Nitrosomonas eutropha is an ammonia-oxidizing bacterium common in high-ammonia wastewater and nitrifying reactors, oxidising ammonia to nitrite aerobically. In this ontology it is represented as a AmmoniaOxidizingBacteria with literature-sourced environmental growth conditions. Sources: Koops H-P, Pommerening-Roser A (2001) Distribution and ecophysiology of the nitrifying bacteria emphasizing cultured species. FEMS Microbiology Ecology 37:1-9.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Nitrosospira_multiformis a :AmmoniaOxidizingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Nitrosospira multiformis" ;
    :OptimalPH "7.5"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "35.0"^^xsd:float ;
    :TemperatureMin "5.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicGrowthOfXaut,
        :AutotrophicNitrification,
        :LysisOfXaut ;
    rdfs:isDefinedBy "Nitrosospira multiformis is a chemolithoautotrophic ammonia-oxidizing bacterium contributing to the first step of nitrification in soils and engineered nitrifying systems. In this ontology it is represented as a AmmoniaOxidizingBacteria with literature-sourced environmental growth conditions. Sources: Koops H-P, Pommerening-Roser A (2001) Distribution and ecophysiology of the nitrifying bacteria emphasizing cultured species. FEMS Microbiology Ecology 37:1-9.; Watson SW et al. (1971) Nitrosospira/Nitrosomonas characterisation; Bergey's Manual of Systematic Bacteriology, 2nd ed." .

:Nitrospira_defluvii a :NitriteOxidizingBacteria,
