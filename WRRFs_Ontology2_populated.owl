    :TemperatureMin "20.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicGrowthOfXaut,
        :AutotrophicNitrification,
        :LysisOfXaut ;
    rdfs:isDefinedBy "Nitrospira defluvii is a nitrite-oxidizing bacterium frequently dominant among Nitrospira in activated-sludge nitrifying communities, oxidising nitrite to nitrate. In this ontology it is represented as a NitriteOxidizingBacteria with literature-sourced environmental growth conditions. Sources: Kitzinger K et al. (2018/2019) Low temperature and neutral pH define Candidatus Nitrotoga as a competitive nitrite oxidizer in coculture with Nitrospira defluvii. Appl Environ Microbiol. [web-verified: Ns. defluvii favours 28-32 C, pH optimum ~7.3]" .

:Nitrospira_moscoviensis a :NitriteOxidizingBacteria,
        owl:NamedIndividual ;
