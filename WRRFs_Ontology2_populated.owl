        owl:NamedIndividual ;
    rdfs:label "Sphaerotilus natans" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "37.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :LysisOfOHOBiomass ;
    rdfs:isDefinedBy "Sphaerotilus natans is a sheathed filamentous heterotrophic bacterium ('sewage fungus') causing bulking in activated sludge, oxidising organic matter aerobically. In this ontology it is represented as a FilamentousBacteria with literature-sourced environmental growth conditions. Sources: Mulder EG, van Veen WL (1963) Investigations on the Sphaerotilus-Leptothrix group; Bergey's Manual.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Stutzerimonas_stutzeri a :DenitrifyingBacteria,
