    rdfs:isDefinedBy "Anaerosacchariphilus polymeriproducens is an anaerobic microorganism capable of reducing thiosulfate, nitrate, and nitrite. In this ontology, it is represented as a microorganism involved in sulfur and nitrogen transformation processes under anaerobic conditions." .

:Anaerosporomusa_subterranea a :AcetogenicSRB,
        owl:NamedIndividual ;
    rdfs:label "Anaerosporomusa subterranea" ;
    :BacDiveID 132639 ;
    :OptimalPH "6.8"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "7.5"^^xsd:float ;
    :PHMin "5.0"^^xsd:float ;
    :TemperatureMax "30.0"^^xsd:float ;
    :TemperatureMin "24.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :reduces :Sulphate ;
    rdfs:isDefinedBy "Anaerosporomusa subterranea is an anaerobic microorganism associated with sulfate reduction under mesophilic conditions. In this ontology, it is represented as a sulfur-reducing microorganism relevant to anaerobic wastewater environments." .

:Andreessenia_angusta a :AcetogenicSRB,
        :DenitrifyingBacteria,
        owl:NamedIndividual ;
    rdfs:label "Andreessenia angusta" ;
    :BacDiveID 5416 ;
    :OptimalPH "7.5"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
    :PHMax "10.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "45.0"^^xsd:float ;
    :TemperatureMin "18.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :reduces :Nitrate,
        :Sulphate ;
    rdfs:isDefinedBy "Andreessenia angusta is an anaerobic microorganism capable of sulfate and nitrate reduction under variable environmental conditions. In this ontology, it is represented as a microorganism associated with sulfur and nitrogen transformation pathways relevant to wastewater treatment systems." .

:BacDiveID a owl:DatatypeProperty ;
    rdfs:domain :Microorganism ;
    rdfs:range xsd:integer .

:Beggiatoa_alba a :SulfurOxidizingbacteria,
        owl:NamedIndividual ;
    rdfs:label "Beggiatoa alba" ;
    :OptimalPH "7.3"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "35.0"^^xsd:float ;
    :TemperatureMin "10.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AutotrophicDenitrification ;
    rdfs:isDefinedBy "Beggiatoa alba is a filamentous sulfur-oxidizing bacterium that oxidises sulfide to elemental sulfur, occurring at oxic-anoxic interfaces and in sulfide-rich wastewater biofilms. In this ontology it is represented as a SulfurOxidizingbacteria with literature-sourced environmental growth conditions. Sources: Strohl WR, Larkin JM (1978) / Mezzino MJ et al. (1984) Characterization of Beggiatoa alba. Arch Microbiol.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:CalciteDissolution a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Calcite ;
    :isDefinedBy "Dissolution of calcite resulting in the release of calcium and carbonate into solution within wastewater treatment systems." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Calcium,
        :Carbonate .

:Candidatus_Accumulibacter_phosphatis a :PhosphateAccumulatingOrganisms,
        owl:NamedIndividual ;
    rdfs:label "Candidatus Accumulibacter phosphatis" ;
    :OptimalPH "7.2"^^xsd:float ;
    :OptimalTemperature "20.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "30.0"^^xsd:float ;
    :TemperatureMin "10.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anaerobic,
        :Anoxic ;
    :performsProcess :AerobicGrowthOfXpa,
        :AerobicStorageOfPP,
        :LysisOfXpa,
        :PPRelease,
        :StorageOfPHAByXpa ;
    :reduces :Nitrate,
        :Nitrite ;
    rdfs:isDefinedBy "Candidatus Accumulibacter phosphatis is the principal polyphosphate-accumulating organism (PAO) driving enhanced biological phosphorus removal, storing polyphosphate aerobically and releasing it anaerobically while taking up volatile fatty acids; some clades denitrify. In this ontology it is represented as a PhosphateAccumulatingOrganisms with literature-sourced environmental growth conditions. Sources: Ong YH et al. (2014) High-temperature EBPR: performance and Candidatus Accumulibacter phosphatis. Water Research 64:102-112. [web-corroborated: stable EBPR 20-30 C]; Hesselmann RPX et al. (1999) Enrichment, phylogenetic analysis of Candidatus Accumulibacter phosphatis, the dominant PAO in EBPR. Syst Appl Microbiol 22:454-465." .

:Candidatus_Competibacter_phosphatis a :GlycogenAccumulatingOrganisms,
        owl:NamedIndividual ;
    rdfs:label "Candidatus Competibacter phosphatis" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "32.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "35.0"^^xsd:float ;
    :TemperatureMin "20.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anaerobic ;
    :performsProcess :HydrolysisOfGlycogen,
        :StorageOfGlycogen,
        :StorageOfPHAByXpa ;
    rdfs:isDefinedBy "Candidatus Competibacter phosphatis is a glycogen-accumulating organism (GAO) that competes with PAOs for volatile fatty acids in EBPR systems, storing glycogen and PHA without net phosphorus removal. In this ontology it is represented as a GlycogenAccumulatingOrganisms with literature-sourced environmental growth conditions. Sources: Lopez-Vazquez CM et al. (2009) Temperature effects on the competition between PAOs and GAOs. Water Research 43:450-462." .

:Candidatus_Microthrix_parvicella a :FilamentousBacteria,
        owl:NamedIndividual ;
    rdfs:label "Candidatus Microthrix parvicella" ;
    :OptimalPH "7.7"^^xsd:float ;
    :OptimalTemperature "25.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "7.0"^^xsd:float ;
    :TemperatureMax "30.0"^^xsd:float ;
    :TemperatureMin "8.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anoxic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :LysisOfOHOBiomass ;
    rdfs:isDefinedBy "Candidatus Microthrix parvicella is a filamentous bacterium responsible for bulking and foaming in activated sludge, a lipid-hydrolysing organism favoured at low temperature and in nutrient-removal plants. In this ontology it is represented as a FilamentousBacteria with literature-sourced environmental growth conditions. Sources: Slijkhuis H (1983) Microthrix parvicella, a filamentous bacterium from activated sludge: cultivation in a chemically defined medium. Appl Environ Microbiol 46(4):832-839. [web-verified: opt ~25 C, pH >7]" .

:Chloride a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "Cl-" ;
    :GujerNotation "S_Cl" ;
    rdfs:isDefinedBy "A dissolved inorganic anion component commonly present in wastewater treatment systems and saline wastewaters. Chloride contributes to salinity, ionic strength, osmotic conditions, conductivity, and corrosion potential, and may influence microbial activity, process performance, and the operation of biological and physicochemical wastewater treatment processes under saline conditions." .

:Clostridium_butyricum a :AcidogenicBacteria,
        owl:NamedIndividual ;
    rdfs:label "Clostridium butyricum" ;
    :OptimalPH "6.5"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "5.0"^^xsd:float ;
    :TemperatureMax "45.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :performsProcess :AcidogenesisHighPH,
        :AcidogenesisLowPH,
        :DeathAndDecayOfSugarDegraders,
        :FermentationOfFSO,
        :UptakeOfSugarsInADM ;
    rdfs:isDefinedBy "Clostridium butyricum is a fermentative acidogenic bacterium producing volatile fatty acids, hydrogen and carbon dioxide from carbohydrates during the acidogenesis step of anaerobic digestion. In this ontology it is represented as a AcidogenicBacteria with literature-sourced environmental growth conditions. Sources: Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Comamonas_testosteroni a :DenitrifyingBacteria,
        :OrdinaryHetetrophicBacteria,
        owl:NamedIndividual ;
    rdfs:label "Comamonas testosteroni" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "32.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "40.0"^^xsd:float ;
    :TemperatureMin "10.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anoxic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AnoxicOHOGrowthOnAcetate,
        :AnoxicOHOGrowthOnFSO,
        :AutotrophicDenitrification,
        :FermentationOfFSO,
        :LysisOfOHOBiomass ;
    :reduces :Nitrate,
        :Nitrite ;
    rdfs:isDefinedBy "Comamonas testosteroni is a versatile ordinary heterotrophic bacterium capable of aerobic organic-carbon oxidation and denitrification, reducing nitrate and nitrite under anoxic conditions. In this ontology it is represented as a OrdinaryHetetrophicBacteria, DenitrifyingBacteria with literature-sourced environmental growth conditions. Sources: Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:DeathAndDecayOfAcetateDegraders a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :AM_Biomass,
        :HydrogenIon ;
    :hasKineticParameter :DecayRate_AM ;
    :isDefinedBy "Endogenous decay and lysis of acetate-degrading methanogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :Sulphate,
        :UnbiodegradableParticulateOrganics .

:DeathAndDecayOfAcetogenicSRB a :SulfurRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon ;
    :hasKineticParameter :DecayRate_ACS ;
    :isDefinedBy "Endogenous decay and lysis of acetogenic sulfate-reducing biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :Sulphate .

:DeathAndDecayOfProprionateDegraders a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :AC_Biomass,
        :HydrogenIon ;
    :hasKineticParameter :DecayRate_AC ;
    :isDefinedBy "Endogenous decay and lysis of proprionate-degrading acetogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :Sulphate,
        :UnbiodegradableParticulateOrganics .

:DecayRate_PAO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_PAO" ;
    :Unit "1/d" ;
    :Value "0.04"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of phosphorus accumulating microorganisms (X_PAO) during enhanced biological phosphorus removal (EBPR)" .

:DecayRate_PAO_AD a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_PAO_AD" ;
    :Unit "1/d" ;
    :Value "20.0"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of phosphorus accumulating microorganisms (X_PAO) under anaerobic digestion conditions" .

:DecayRate_PHA a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_PHA" ;
    :Unit "1/d" ;
    :Value "0.04"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate associated with the degradation and consumption of internally stored polyhydroxyalkanoates (X_PHA) by phosphorus accumulating microorganisms during enhanced biological phosphorus removal" .

:DecayRate_PP a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_PP" ;
    :Unit "1/d" ;
    :Value "0.04"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate associated with the degradation of internally stored polyphosphate (X_PP) by phosphorus accumulating microorganisms during enhanced biological phosphorus removal" .

:Defluviicoccus_vanus a :GlycogenAccumulatingOrganisms,
        owl:NamedIndividual ;
    rdfs:label "Defluviicoccus vanus" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "30.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "37.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic,
        :Anaerobic ;
    :performsProcess :HydrolysisOfGlycogen,
        :StorageOfGlycogen,
        :StorageOfPHAByXpa ;
    rdfs:isDefinedBy "Defluviicoccus vanus is a glycogen-accumulating organism found in EBPR activated sludge that competes with PAOs for carbon under alternating anaerobic-aerobic conditions. In this ontology it is represented as a GlycogenAccumulatingOrganisms with literature-sourced environmental growth conditions. Sources: Maszenan AM et al. (2005) Defluvicoccus vanus gen. nov., sp. nov., a novel Gammaproteobacterium. Int J Syst Evol Microbiol 55:2105-2111." .

:EmpiricalFormula a owl:DatatypeProperty ;
    rdfs:domain :Component ;
    rdfs:isDefinedBy "A component that is dissolved within the liquid phase of a wastewater treatment system and is not present as suspended solids. Soluble components include dissolved substrates, nutrients, ions, gases, and metabolic products that are readily available for transport, microbial uptake, chemical reactions, and biological transformation processes during wastewater treatment." ;
    rdfs:range xsd:string .

:EvolutionOfCO2Gas a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Carbonate,
        :HydrogenIon ;
    :isDefinedBy "Evolution and release of dissolved inorganic carbon as carbon dioxide gas during wastewater treatment and anaerobic digestion processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :CarbonDioxide .

:Fungi a owl:Class ;
    rdfs:subClassOf :Eukarya .

:GujerNotation a owl:DatatypeProperty ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy "A standardised notation system used in wastewater treatment modelling to represent components, state variables, and biological or chemical processes within stoichiometric matrices such as the Gujer matrix. Gujer notation provides a consistent framework for describing soluble and particulate components, microbial biomass, substrates, and transformation processes, thereby supporting mass balance calculations, process modelling, simulation, and communication between wastewater treatment models and researchers." ;
    rdfs:range xsd:string .

:HalfSatCoeff_BInf_AD_hyd a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_BInf_AD_hyd" ;
    :Unit "gCOD/gCOD" ;
    :Value "10.124"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for biodegradable particulate sewage organics during anaerobic hydrolysis" .

:HydrolysisOfBPO a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :BiodegradableParticulateOrganics,
        :Carbonate,
        :HydrogenIon ;
    :hasKineticParameter :HalfSatCoeff_BOrg_AD_hyd ;
    :isDefinedBy "Hydrolysis of biodegradable particulate organics into soluble biodegradable substrates that can be used in downstream anaerobic conversion processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :Glucose,
        :Phosphate,
        :Sulphate .

:HydrolysisOfBPOPS a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon,
        :PrimarySludgeBiodegradableParticulateOrganics ;
    :isDefinedBy "Hydrolysis of primary sludge biodegradable particulate organics into soluble biodegradable products for further anaerobic conversion." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :Glucose,
        :Phosphate,
        :Sulphate .

:HydrolysisOfDeadBiomassBiodegradableParticulate a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :BiodegradableParticulateOrganics,
        :HydrogenIon ;
    :isDefinedBy "Hydrolysis of biodegradable dead biomass particulate material into soluble biodegradable substrates during wastewater treatment processes." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :FermentableBiodegradableSolubleOrganics,
        :Phosphate .

:HydrolysisOfFSO a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :FermentableBiodegradableSolubleOrganics ;
    :isDefinedBy "Hydrolysis of fermentable biodegradable soluble organics into simpler soluble products that can be further utilised during anaerobic digestion." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :Glucose,
        :HydrogenIon,
        :Phosphate,
        :Sulphate .

:HydrolysisOfPHA a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Carbonate,
        :HydrogenIon,
        :Polyhydroxyalkanoate ;
    :isDefinedBy "Hydrolysis of polyhydroxyalkanoate storage compounds into soluble organic products used for microbial metabolism." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Glucose .

:HydrolysisOfPP a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Polyphosphate ;
    :isDefinedBy "Hydrolysis of intracellular polyphosphate to release phosphate and associated ions in biological phosphorus removal processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Calcium,
        :HydrogenIon,
        :Magnesium,
        :Phosphate,
        :Potassium .

:InfluentBiodegradableParticulateHydrolysis a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon,
        :PrimarySludgeBiodegradableParticulateOrganics ;
    :isDefinedBy "Hydrolysis of influent biodegradable particulate organics into soluble biodegradable substrates during biological wastewater treatment processes." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :FermentableBiodegradableSolubleOrganics,
        :Phosphate .

:InfluentInorganicSettleableSolids a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYISSOzISSNAISSPBISS" ;
    :GujerNotation "X_ISS" ;
    rdfs:isDefinedBy "A particulate inorganic component consisting of settleable suspended solids entering a wastewater treatment system with the influent flow. Influent inorganic settleable solids include materials such as sand, grit, silt, and mineral particles that do not readily undergo biological degradation but influence sedimentation, sludge production, hydraulic performance, abrasion, and solids handling processes within wastewater treatment systems." .

:Kstruvite a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "MgKPO4.6H2O" ;
    :GujerNotation "X_Str_K" ;
    rdfs:isDefinedBy "A mineral component representing potassium struvite, typically composed of magnesium, ammonium, phosphate, and potassium-containing crystalline compounds formed under specific chemical conditions in wastewater treatment systems. Kstruvite is associated with nutrient precipitation, phosphorus and nitrogen recovery, scaling, mineral formation, and resource recovery processes within sludge treatment and wastewater management systems." .

:LysisOfPAOBiomass a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :PAO_Biomass ;
    :isDefinedBy "Lysis of phosphate-accumulating organism biomass into biodegradable particulate organics and endogenous residue during biomass decay." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :HydrogenIon,
        :Phosphate,
        :UnbiodegradableParticulateOrganics .

:LysisOfPHA a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Polyhydroxyalkanoate ;
    :isDefinedBy "Lysis of intracellular polyhydroxyalkanoate storage material into soluble organic products during biological wastewater treatment processes." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :Carbonate,
        :HydrogenIon,
        :VolatileFattyAcids .

:LysisOfPP a :PhosphorusRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Polyphosphate ;
    :isDefinedBy "Lysis of intracellular polyphosphate resulting in the release of phosphate and associated ions during biological phosphorus transformation processes." ;
    :occursIn :AerobicBioreactor ;
    :producesProduct :Calcium,
        :HydrogenIon,
        :Magnesium,
        :Phosphate,
        :Potassium .

:MagnesiteDissolution a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Magnesite ;
    :isDefinedBy "Dissolution of magnesite resulting in the release of magnesium and carbonate into solution within wastewater treatment systems." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Carbonate,
        :Magnesium .

:MaxGrowthRate_PAO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "mu_PAO" ;
    :Unit "1/d" ;
    :Value "1.0"^^xsd:float ;
    rdfs:isDefinedBy "Maximum specific growth rate for phosphorus accumulating microorganisms" .

:Methanobacterium_formicicum a :HydrogenotrophicMethanogen,
        owl:NamedIndividual ;
    rdfs:label "Methanobacterium formicicum" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "40.0"^^xsd:float ;
    :PHMax "7.8"^^xsd:float ;
    :PHMin "6.6"^^xsd:float ;
    :TemperatureMax "45.0"^^xsd:float ;
    :TemperatureMin "25.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :performsProcess :HydrogenotrophicMethanogenesis,
        :UptakeOfHydrogenInADM,
        :XhmEndogenousDecay ;
    rdfs:isDefinedBy "Methanobacterium formicicum is a hydrogenotrophic methanogen producing methane from hydrogen/carbon dioxide and formate, contributing to the final step of anaerobic digestion. In this ontology it is represented as a HydrogenotrophicMethanogen with literature-sourced environmental growth conditions. Sources: Bryant MP, Boone DR (1987) Emended description of Methanosarcina/Methanobacterium. Int J Syst Bacteriol 37:169-170; Bergey's Manual.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Methanoculleus_bourgensis a :HydrogenotrophicMethanogen,
        owl:NamedIndividual ;
    rdfs:label "Methanoculleus bourgensis" ;
    :OptimalPH "6.7"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "45.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :performsProcess :HydrogenotrophicMethanogenesis,
        :UptakeOfHydrogenInADM,
        :XhmEndogenousDecay ;
    rdfs:isDefinedBy "Methanoculleus bourgensis is a hydrogenotrophic methanogen that reduces carbon dioxide with hydrogen (and formate) to methane, common in anaerobic digesters treating waste. In this ontology it is represented as a HydrogenotrophicMethanogen with literature-sourced environmental growth conditions. Sources: Ollivier BM et al. (1986) Methanogenium (Methanoculleus) bourgense sp. nov. Int J Syst Bacteriol 36:297-301." .

:Methanosarcina_barkeri a :AcetoclasticMethanogen,
        :HydrogenotrophicMethanogen,
        owl:NamedIndividual ;
    rdfs:label "Methanosarcina barkeri" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "37.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "45.0"^^xsd:float ;
    :TemperatureMin "25.0"^^xsd:float ;
    :hasOxygenNiche :Anaerobic ;
    :performsProcess :AcetoclasticMethanogenesis,
        :HydrogenotrophicMethanogenesis,
        :UptakeOfAcetateInADM,
        :UptakeOfHydrogenInADM,
        :XacEndogenousDecay,
        :XhmEndogenousDecay ;
    rdfs:isDefinedBy "Methanosarcina barkeri is a metabolically versatile methanogen able to form methane from acetate, hydrogen/carbon dioxide and methylated compounds, important in anaerobic digestion at higher acetate levels. In this ontology it is represented as a AcetoclasticMethanogen, HydrogenotrophicMethanogen with literature-sourced environmental growth conditions. Sources: Bryant MP, Boone DR (1987) Emended description of Methanosarcina/Methanobacterium. Int J Syst Bacteriol 37:169-170; Bergey's Manual.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Methanospirillum_hungatei a :HydrogenotrophicMethanogen,
        owl:NamedIndividual ;
