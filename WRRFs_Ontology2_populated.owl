    :reduces :Nitrate,
        :Nitrite ;
    rdfs:isDefinedBy "Thiobacillus denitrificans is a chemolithoautotrophic sulfur-oxidizing bacterium that couples oxidation of reduced sulfur compounds to denitrification, reducing nitrate and nitrite under anoxic conditions. In this ontology it is represented as a SulfurOxidizingbacteria, DenitrifyingBacteria with literature-sourced environmental growth conditions. Sources: Kelly DP, Wood AP (2000) Reclassification of Thiobacillus; Thiobacillus denitrificans. Int J Syst Evol Microbiol 50:511-516.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:Thiothrix_nivea a :FilamentousBacteria,
        :SulfurOxidizingbacteria,
        owl:NamedIndividual ;
    rdfs:label "Thiothrix nivea" ;
    :OptimalPH "7.5"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "8.5"^^xsd:float ;
    :PHMin "6.5"^^xsd:float ;
    :TemperatureMax "35.0"^^xsd:float ;
    :TemperatureMin "10.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :AnoxicGrowthOfAutotrophicDenitrifiers,
        :AutotrophicDenitrification,
        :LysisOfOHOBiomass ;
    rdfs:isDefinedBy "Thiothrix nivea is a filamentous sulfur-oxidizing bacterium that stores elemental sulfur intracellularly and is associated with bulking in activated sludge under sulfide-rich conditions. In this ontology it is represented as a FilamentousBacteria, SulfurOxidizingbacteria with literature-sourced environmental growth conditions. Sources: Larkin JM, Shinabarger DL (1983) Characterization of Thiothrix nivea. Int J Syst Bacteriol 33:841-846." .

:UnbiodegradableSolubleOrganics a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYuOZuNAuPBu",
        "S_U" ;
    rdfs:isDefinedBy "A soluble organic component consisting of dissolved organic matter that cannot be readily degraded or biologically transformed by microorganisms within wastewater treatment systems. Unbiodegradable soluble organics persist in the liquid phase throughout treatment processes and contribute to residual chemical oxygen demand, effluent organic content, and the accumulation of refractory organic compounds within wastewater treatment and resource recovery systems." .

:Unit a owl:DatatypeProperty ;
    rdfs:domain :Parameters ;
    rdfs:isDefinedBy "A standardised measurement reference used to express the magnitude, concentration, rate, or quantity of a parameter or component within a wastewater treatment system. Units provide consistency and comparability in process modelling, stoichiometric calculations, experimental analysis, operational monitoring, and engineering design by defining how variables such as mass, volume, concentration, time, and reaction rates are quantified." ;
    rdfs:range xsd:string .

:UptakeOfProprionateInADM a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon ;
    :hasKineticParameter :DecayRate_AC,
        :MaxGrowthRate_AC ;
    :isDefinedBy "Anaerobic uptake and degradation of proprionate by acetogenic microorganisms resulting in the production of acetate, hydrogen, and acetogenic biomass during anaerobic digestion processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :AC_Biomass,
        :Ammonium,
        :Carbonate,
        :Hydrogen,
        :Phosphate,
        :Sulphate,
        :VolatileFattyAcids .

:Value a owl:DatatypeProperty ;
    rdfs:isDefinedBy "A numerical or categorical quantity assigned to a parameter, component, or operational condition within a wastewater treatment system. Values are used to represent measured, estimated, or modelled data such as concentrations, reaction rates, kinetic coefficients, environmental conditions, and stoichiometric relationships, thereby supporting process monitoring, simulation, calibration, validation, and engineering analysis." ;
    rdfs:range xsd:float .

:XamEndogenousDecay a :CarbonRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :AM_Biomass,
        :HydrogenIon ;
    :hasKineticParameter :DecayRate_AM ;
    :isDefinedBy "Endogenous decay and lysis of acetoclastic methanogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :UnbiodegradableParticulateOrganics .

:YieldCoeff_ANO a :StoichiometricParameter,
        owl:NamedIndividual ;
    :GujerNotation "Y_ANO" ;
    :Unit "COD/COD" ;
    :Value "0.24"^^xsd:float .

:YieldCoeff_OHO a :StoichiometricParameter,
        owl:NamedIndividual ;
    :GujerNotation "Y_OHO" ;
    :Unit "COD/COD" ;
    :Value "0.67"^^xsd:float ;
    rdfs:isDefinedBy "Yield coefficient for ordinary heterotrophic organisms (OHO)" .

:YieldCoeff_PAO a :StoichiometricParameter,
        owl:NamedIndividual ;
    :GujerNotation "Y_PAO" ;
    :Unit "COD/COD" ;
    :Value "0.67"^^xsd:float ;
    rdfs:isDefinedBy "Yield coefficient for phosphorus accumulating organisms (PAO)" .

:Zoogloea_ramigera a :OrdinaryHetetrophicBacteria,
        owl:NamedIndividual ;
    rdfs:label "Zoogloea ramigera" ;
    :OptimalPH "7.0"^^xsd:float ;
    :OptimalTemperature "28.0"^^xsd:float ;
    :PHMax "8.0"^^xsd:float ;
    :PHMin "6.0"^^xsd:float ;
    :TemperatureMax "37.0"^^xsd:float ;
    :TemperatureMin "15.0"^^xsd:float ;
    :hasOxygenNiche :Aerobic ;
    :performsProcess :AerobicOHOGrowthOnFSO,
        :AnoxicOHOGrowthOnAcetate,
        :AnoxicOHOGrowthOnFSO,
        :FermentationOfFSO,
        :LysisOfOHOBiomass ;
    rdfs:isDefinedBy "Zoogloea ramigera is a floc-forming ordinary heterotrophic bacterium characteristic of activated sludge, contributing to organic carbon removal and floc structure. In this ontology it is represented as a OrdinaryHetetrophicBacteria with literature-sourced environmental growth conditions. Sources: Rossello-Mora RA et al. (1995) Zoogloea ramigera: reclassification; Bergey's Manual.; Bergey's Manual of Systematic Bacteriology (2nd ed.) / Bergey's Manual of Systematics of Archaea and Bacteria." .

:consumesSubstrate a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process utilises or removes a specific component as a reactant, substrate, electron donor, electron acceptor, or nutrient during transformation within a wastewater treatment system. This relationship represents the uptake or conversion of components required for process activity, microbial metabolism, and contaminant removal." ;
    rdfs:range :Component .

:hasInhibitor a owl:ObjectProperty ;
    rdfs:domain :Microorganism ;
    rdfs:isDefinedBy "A relationship indicating that a specific component negatively affects, limits, or suppresses the activity, growth, or performance of a microorganism or process within a wastewater treatment system. Inhibition may occur due to toxic compounds, high substrate concentrations, environmental stress conditions, or metabolic by-products that interfere with microbial metabolism, reaction kinetics, or treatment efficiency." ;
    rdfs:range :Component ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasIntermediate a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a component is formed, transformed, or temporarily produced during the progression of a biological, chemical, or physical process within a wastewater treatment system before being further consumed or converted into final products. Intermediate compounds play important roles in metabolic pathways, nutrient cycling, sulfur transformations, carbon conversion, and process interactions within wastewater treatment and resource recovery systems." ;
    rdfs:range :Component ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasKineticParameter a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:range :KineticParameter ;
    rdfs:subPropertyOf :hasParameter ;
    owl:propertyDisjointWith :hasStoichiometricParameter .

:hasOxygenNiche a owl:ObjectProperty ;
    rdfs:domain :Microorganism ;
    rdfs:range :OxygenNiche ;
    rdfs:subPropertyOf owl:topObjectProperty .

:isDefinedBy a owl:AnnotationProperty .

:occursIn a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process takes place within a specific reactor, treatment unit, environmental zone, or operational condition in a wastewater treatment system. This relationship is used to associate processes with the environments that support or regulate their activity, such as aerobic, anoxic, anaerobic, or saline treatment conditions." ;
    rdfs:range :Bioreactor ;
    rdfs:subPropertyOf owl:topObjectProperty .

:performsProcess a owl:ObjectProperty ;
    rdfs:domain :Microorganism ;
    rdfs:isDefinedBy "A relationship indicating that a microorganism or microbial functional group carries out or participates in a specific biological, chemical, or metabolic process within a wastewater treatment system. This relationship links microbial activity to treatment functions such as nitrification, denitrification, fermentation, sulfate reduction, phosphorus removal, and methanogenesis, thereby representing the role of microorganisms in wastewater transformation and resource recovery processes." ;
    rdfs:range :Process .

:producesProduct a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process generates, releases, or forms a specific component as an output or end product within a wastewater treatment system. Products may include transformed substrates, metabolic by-products, gases, nutrients, biomass, or intermediate compounds produced during microbial activity, chemical reactions, and treatment processes." ;
    rdfs:range :Component ;
    rdfs:subPropertyOf owl:topObjectProperty .

:reduces a owl:ObjectProperty ;
    rdfs:domain :Microorganism ;
    rdfs:range :Component .

:symbol a owl:AnnotationProperty .

:usesElectronAcceptor a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or microbial process utilises a specific compound as the terminal electron acceptor during metabolic or redox reactions within a wastewater treatment system. Electron acceptors such as oxygen, nitrate, nitrite, sulfate, or carbon dioxide determine the environmental conditions under which processes occur and strongly influence microbial activity, energy generation, reaction pathways, and treatment performance." ;
    rdfs:range :Component ;
    rdfs:subPropertyOf owl:topObjectProperty .

:usesElectronDonor a owl:ObjectProperty ;
    rdfs:domain :Process ;
    rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or microbial process utilises a specific compound as the source of electrons during metabolic or redox reactions within a wastewater treatment system. Electron donors such as organic matter, acetate, hydrogen, sulfide, or ammonia provide the energy and reducing power required for microbial growth, substrate transformation, nutrient removal, and biochemical conversion processes." ;
    rdfs:range :Component ;
    rdfs:subPropertyOf owl:topObjectProperty .

:Acidogens_Biomass a :MicroorganismBiomass,
        owl:NamedIndividual ;
    :EmpiricalFormula "CHYoOZoNAoPBo" ;
    :GujerNotation "X_ZAD" ;
    rdfs:isDefinedBy "A biomass component representing acidogenic microorganisms involved in the anaerobic conversion of complex organic matter into simpler soluble compounds such as volatile fatty acids, alcohols, hydrogen, and carbon dioxide during fermentation processes in wastewater treatment systems. Acidogenic biomass plays a key role in anaerobic digestion, carbon transformation, and the production of intermediates used in downstream microbial processes such as acetogenesis and methanogenesis." .

:Archaea a owl:Class ;
    rdfs:isDefinedBy "A domain of single-celled prokaryotic microorganisms that are genetically and metabolically distinct from bacteria. In wastewater treatment systems, archaea are particularly important in anaerobic processes such as methanogenesis, where methanogenic archaea convert substrates such as acetate, hydrogen, and carbon dioxide into methane during anaerobic digestion and resource recovery processes." ;
    rdfs:subClassOf :Microorganism .

:Calcite a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "CaCO3" ;
    :GujerNotation "X_Cal" ;
    rdfs:isDefinedBy "A mineral calcium carbonate component that may form, dissolve, or precipitate within wastewater treatment systems under specific chemical and environmental conditions. Calcite plays an important role in alkalinity balance, phosphorus precipitation, scaling, mineral formation, and inorganic carbon transformations in wastewater treatment and resource recovery processes." .

:CalciumPhosphate a :Particulate,
        owl:NamedIndividual ;
    :EmpiricalFormula "Ca3(PO4)2",
        "X_ACP" ;
    rdfs:isDefinedBy "A mineral component consisting of calcium and phosphate compounds that may form through chemical or biological precipitation processes in wastewater treatment systems. Calcium phosphate plays an important role in phosphorus removal, nutrient recovery, sludge composition, scaling, and mineral formation under specific chemical and environmental conditions within wastewater treatment and resource recovery processes." .

:DeathAndDecayOfHydrogenotrophicSRB a :SulfurRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :HydrogenIon ;
    :hasKineticParameter :DecayRate_HS ;
    :isDefinedBy "Endogenous decay and lysis of hydrogenotrophic sulfate-reducing biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :BiodegradableParticulateOrganics,
        :Carbonate,
        :EndogenousResidue,
        :Phosphate,
        :Sulphate .

:DecayRate_ANO a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_ANO" ;
    :Unit "1/d" ;
    :Value "0.15"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of autotrophic nitrifying microorganisms (X_ANO) during aerobic nitrification" .

:DecayRate_AS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_AS" ;
    :Unit "1/d" ;
    :Value "0.0275"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of autotrophic sulfur oxidizing microorganisms (X_AS) during sulfur oxidation and autotrophic denitrification" .

:DecayRate_OHO_AD a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "b_OHO_AD" ;
    :Unit "1/d" ;
    :Value "20.0"^^xsd:float ;
    rdfs:isDefinedBy "Decay rate describing the lysis and endogenous respiration of ordinary heterotrophic microorganisms (X_OHO) under anaerobic digestion conditions" .

:ElementalSulfur a :Soluble,
        owl:NamedIndividual ;
    :EmpiricalFormula "S0" ;
    :GujerNotation "S_S0" ;
    rdfs:isDefinedBy "Elemental sulfur is an inorganic sulfur component with oxidation state zero. In wastewater treatment systems, it can occur as an intermediate in sulfur oxidation and reduction pathways and may be reduced by sulfur-reducing microorganisms." .

:GrowthOfAcetoclasticSRB a :SulfurRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Acetate,
        :Ammonium,
        :Carbonate,
        :Phosphate,
        :Sulphate,
        :VolatileFattyAcids ;
    :hasKineticParameter :DecayRate_AS,
        :H2SInhibition_AS,
        :HalfSatCoeff_AS,
        :HalfSatCoeff_N_AS,
        :MaxGrowthRate_AS ;
    :hasStoichiometricParameter :YieldCoeff_AS ;
    :isDefinedBy "Growth of acetoclastic sulfate-reducing biomass through the anaerobic oxidation of acetate coupled with sulfate reduction, resulting in sulfide production and biomass formation in wastewater treatment systems." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Carbonate,
        :HydrogenIon,
        :HydrogenSulfide,
        :Water ;
    :usesElectronAcceptor :Sulphate ;
    :usesElectronDonor :Acetate,
        :VolatileFattyAcids ;
    rdfs:isDefinedBy """Growth of acetoclastic sulfate-reducing biomass is an anaerobic sulfur transformation process in which acetoclastic sulfate-reducing microorganisms use acetate-rich volatile fatty acids as electron donors while reducing sulfate (SO₄²⁻) to sulfide species.

This process links carbon degradation with sulfur reduction by converting organic substrates into carbonate species while producing hydrogen sulfide and new sulfate-reducing biomass. Acetoclastic sulfate reduction is important in sulfate-rich wastewater environments because it competes with acetoclastic methanogenesis for acetate and can influence methane production, sulfide accumulation, alkalinity, and overall anaerobic reactor performance.""" .

:GrowthOfAcetogenicSRBBiomass a :SulfurRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :HydrogenIon,
        :Phosphate,
        :Propionate,
        :Sulphate ;
    :hasKineticParameter :DecayRate_ACS,
        :H2SInhibition_ACS,
        :HalfSatCoeff_ACS,
        :HalfSatCoeff_N_ACS,
        :MaxGrowthRate_ACS ;
    :hasStoichiometricParameter :YieldCoeff_ACS ;
    :isDefinedBy "Growth of acetogenic sulfate-reducing biomass through the anaerobic degradation of proprionate coupled with sulfate reduction, resulting in sulfide production and biomass formation in wastewater treatment systems." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :Ammonium,
        :Carbonate,
        :Hydrogen,
        :HydrogenIon,
        :HydrogenSulfide,
        :Phosphate,
        :VolatileFattyAcids,
        :Water ;
    :usesElectronAcceptor :Sulphate ;
    :usesElectronDonor :Propionate ;
    rdfs:isDefinedBy """Growth of acetogenic sulfate-reducing biomass is an anaerobic sulfur transformation process in which acetogenic sulfate-reducing microorganisms oxidise propionate and related organic substrates while reducing sulfate (SO₄²⁻) to sulfide species such as hydrogen sulfide (H₂S).

Propionate functions as the electron donor, while sulfate acts as the terminal electron acceptor. This process contributes to sulfur cycling, organic matter degradation, and sulfide production under anaerobic conditions. It is particularly relevant in saline and sulfate-rich wastewater systems, where sulfate-reducing microorganisms compete with methanogens for available electron donors and influence methane production, sulfide formation, and reactor stability.""" .

:GrowthOfHydrogenotrophicSRB a :SulfurRemovalProcess,
        owl:NamedIndividual ;
    :consumesSubstrate :Ammonium,
        :Carbonate,
        :Hydrogen,
        :Phosphate,
        :Sulphate ;
    :hasKineticParameter :DecayRate_HS,
        :H2SInhibition_HS,
        :HalfSatCoeff_HS,
        :HalfSatCoeff_N_HS,
        :MaxGrowthRate_HS ;
    :hasStoichiometricParameter :YieldCoeff_HS ;
    :isDefinedBy "Growth of hydrogenotrophic sulfate-reducing biomass through the anaerobic oxidation of hydrogen coupled with sulfate reduction, resulting in sulfide production and biomass formation in wastewater treatment systems." ;
    :occursIn :AnaerobicBioreactor ;
    :producesProduct :HydrogenIon,
        :HydrogenSulfide,
        :Water ;
    :usesElectronAcceptor :Sulphate ;
    :usesElectronDonor :Hydrogen ;
    rdfs:isDefinedBy """Growth of hydrogenotrophic sulfate-reducing biomass is an anaerobic sulfur transformation process in which hydrogenotrophic sulfate-reducing microorganisms use hydrogen (H₂) as the electron donor and sulfate (SO₄²⁻) as the terminal electron acceptor to produce sulfide species and new biomass.

This process is significant in sulfate-rich anaerobic wastewater systems because it consumes hydrogen that may otherwise support hydrogenotrophic methanogenesis. By reducing sulfate to sulfide, hydrogenotrophic sulfate-reducing microorganisms contribute to sulfur cycling, influence methane production pathways, and affect sulfide accumulation, corrosion potential, odour formation, and process stability.""" .

:H2SInhibition_ACS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "K_I_HS_ACS" ;
    :Unit "gS/m³" ;
    :Value "0.185"^^xsd:float ;
    rdfs:isDefinedBy "H₂S inhibition coefficient for acetogenic sulfate-reducing microorganisms" .

:H2SInhibition_AS a :KineticParameter,
