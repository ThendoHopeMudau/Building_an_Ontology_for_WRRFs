    :GujerNotation "KS_ACS" ;
    :Unit "g/m³" ;
    :Value "2.631"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for acetogenic sulfate-reducing microorganisms" .

:HalfSatCoeff_AM a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_AM" ;
    :Unit "g/m³" ;
    :Value "0.013"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for acetoclastic methanogenic microorganisms" .

:HalfSatCoeff_AS a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_AS" ;
    :Unit "g/m³" ;
    :Value "0.3747"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for acetoclastic sulfate-reducing microorganisms" .

:HalfSatCoeff_BOrg_AD_hyd a :KineticParameter,
        owl:NamedIndividual ;
    :GujerNotation "KS_BOrg_AD_hyd" ;
    :Unit "gCOD/gCOD" ;
    :Value "10.37"^^xsd:float ;
    rdfs:isDefinedBy "Half-saturation coefficient for biodegradable particulate organics produced from biomass decay during anaerobic hydrolysis" .

:HalfSatCoeff_HM a :KineticParameter,
