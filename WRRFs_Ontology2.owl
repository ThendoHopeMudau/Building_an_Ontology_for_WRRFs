@prefix : <http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#> .

<http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2> rdf:type owl:Ontology ;
                                                                     rdfs:comment "A knowledge model for wastewater treatment systems that models microorganisms, their traits, functional roles, metabolic processes, operational indicators, and interactions with environmental conditions to support modelling, monitoring, and resource recovery applications." .

#################################################################
#    Annotation properties
#################################################################

###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#isDefinedBy
:isDefinedBy rdf:type owl:AnnotationProperty .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#symbol
:symbol rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#consumesSubstrate
:consumesSubstrate rdf:type owl:ObjectProperty ;
                   rdfs:domain :Process ;
                   rdfs:range :Component ;
                   rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process utilises or removes a specific component as a reactant, substrate, electron donor, electron acceptor, or nutrient during transformation within a wastewater treatment system. This relationship represents the uptake or conversion of components required for process activity, microbial metabolism, and contaminant removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasInhibitor
:hasInhibitor rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:domain :Microorganism ;
              rdfs:range :Component ;
              rdfs:isDefinedBy "A relationship indicating that a specific component negatively affects, limits, or suppresses the activity, growth, or performance of a microorganism or process within a wastewater treatment system. Inhibition may occur due to toxic compounds, high substrate concentrations, environmental stress conditions, or metabolic by-products that interfere with microbial metabolism, reaction kinetics, or treatment efficiency." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasIntermediate
:hasIntermediate rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Process ;
                 rdfs:range :Component ;
                 rdfs:isDefinedBy "A relationship indicating that a component is formed, transformed, or temporarily produced during the progression of a biological, chemical, or physical process within a wastewater treatment system before being further consumed or converted into final products. Intermediate compounds play important roles in metabolic pathways, nutrient cycling, sulfur transformations, carbon conversion, and process interactions within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasKineticParameter
:hasKineticParameter rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasParameter ;
                     rdfs:domain :Process ;
                     rdfs:range :KineticParameter ;
                     owl:propertyDisjointWith :hasStoichiometricParameter .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasOxygenNiche
:hasOxygenNiche rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                rdfs:domain :Microorganism ;
                rdfs:range :OxygenNiche .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasParameter
:hasParameter rdf:type owl:ObjectProperty ;
              rdfs:domain :Process ;
              rdfs:range :Parameters ;
              rdfs:isDefinedBy "A relationship indicating that a process, microorganism, component, or system entity is associated with a quantitative or qualitative variable used to describe its behaviour, characteristics, or performance within a wastewater treatment system. Parameters may represent kinetic behaviour, stoichiometric relationships, environmental conditions, operational settings, or system properties used in process modelling, simulation, monitoring, and engineering analysis." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#hasStoichiometricParameter
:hasStoichiometricParameter rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf :hasParameter ;
                            rdfs:domain :Process ;
                            rdfs:range :StoichiometricParameter .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#occursIn
:occursIn rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf owl:topObjectProperty ;
          rdf:type owl:AsymmetricProperty ;
          rdfs:domain :Process ;
          rdfs:range :Bioreactor ;
          rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process takes place within a specific reactor, treatment unit, environmental zone, or operational condition in a wastewater treatment system. This relationship is used to associate processes with the environments that support or regulate their activity, such as aerobic, anoxic, anaerobic, or saline treatment conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#performsProcess
:performsProcess rdf:type owl:ObjectProperty ;
                 rdfs:domain :Microorganism ;
                 rdfs:range :Process ;
                 rdfs:isDefinedBy "A relationship indicating that a microorganism or microbial functional group carries out or participates in a specific biological, chemical, or metabolic process within a wastewater treatment system. This relationship links microbial activity to treatment functions such as nitrification, denitrification, fermentation, sulfate reduction, phosphorus removal, and methanogenesis, thereby representing the role of microorganisms in wastewater transformation and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#producesProduct
:producesProduct rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain :Process ;
                 rdfs:range :Component ;
                 rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or physical process generates, releases, or forms a specific component as an output or end product within a wastewater treatment system. Products may include transformed substrates, metabolic by-products, gases, nutrients, biomass, or intermediate compounds produced during microbial activity, chemical reactions, and treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#reduces
:reduces rdf:type owl:ObjectProperty ;
         rdfs:domain :Microorganism ;
         rdfs:range :Component .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#usesElectronAcceptor
:usesElectronAcceptor rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain :Process ;
                      rdfs:range :Component ;
                      rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or microbial process utilises a specific compound as the terminal electron acceptor during metabolic or redox reactions within a wastewater treatment system. Electron acceptors such as oxygen, nitrate, nitrite, sulfate, or carbon dioxide determine the environmental conditions under which processes occur and strongly influence microbial activity, energy generation, reaction pathways, and treatment performance." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#usesElectronDonor
:usesElectronDonor rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty ;
                   rdfs:domain :Process ;
                   rdfs:range :Component ;
                   rdfs:isDefinedBy "A relationship indicating that a biological, chemical, or microbial process utilises a specific compound as the source of electrons during metabolic or redox reactions within a wastewater treatment system. Electron donors such as organic matter, acetate, hydrogen, sulfide, or ammonia provide the energy and reducing power required for microbial growth, substrate transformation, nutrient removal, and biochemical conversion processes." .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#BacDiveID
:BacDiveID rdf:type owl:DatatypeProperty ;
           rdfs:domain :Microorganism ;
           rdfs:range xsd:integer .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#EmpiricalFormula
:EmpiricalFormula rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Component ;
                  rdfs:range xsd:string ;
                  rdfs:isDefinedBy "A component that is dissolved within the liquid phase of a wastewater treatment system and is not present as suspended solids. Soluble components include dissolved substrates, nutrients, ions, gases, and metabolic products that are readily available for transport, microbial uptake, chemical reactions, and biological transformation processes during wastewater treatment." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#GujerNotation
:GujerNotation rdf:type owl:DatatypeProperty ;
               rdfs:domain owl:Thing ;
               rdfs:range xsd:string ;
               rdfs:isDefinedBy "A standardised notation system used in wastewater treatment modelling to represent components, state variables, and biological or chemical processes within stoichiometric matrices such as the Gujer matrix. Gujer notation provides a consistent framework for describing soluble and particulate components, microbial biomass, substrates, and transformation processes, thereby supporting mass balance calculations, process modelling, simulation, and communication between wastewater treatment models and researchers." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#KineticParameter
:KineticParameter rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Process ;
                  rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OperationalCondition
:OperationalCondition rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Microorganism ;
                      rdfs:range xsd:float ;
                      rdfs:isDefinedBy "A set of physical, chemical, biological, or environmental conditions under which a wastewater treatment process or reactor operates. Operational conditions include parameters such as temperature, pH, dissolved oxygen concentration, salinity, hydraulic retention time, sludge retention time, mixing intensity, and substrate loading, all of which influence microbial activity, process kinetics, treatment efficiency, and overall system performance." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OptimalPH
:OptimalPH rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :PH ;
           rdfs:domain :Microorganism ;
           rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OptimalTemperature
:OptimalTemperature rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :Temperature ;
                    rdfs:domain :Microorganism ;
                    rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PH
:PH rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :OperationalCondition ;
    rdfs:domain :Microorganism ;
    rdfs:range xsd:float ;
    rdfs:isDefinedBy "A measure of the acidity or alkalinity of a wastewater treatment environment, expressed as the concentration of hydrogen ions in solution. pH influences microbial activity, enzyme function, chemical equilibria, nutrient availability, reaction kinetics, and overall treatment performance, making it a critical operational parameter in wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PHMax
:PHMax rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf :PH ;
       rdfs:domain :Microorganism ;
       rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PHMin
:PHMin rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf :PH ;
       rdfs:domain :Microorganism ;
       rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Parameter
:Parameter rdf:type owl:DatatypeProperty ;
           rdfs:domain :Process ;
           rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Salinity
:Salinity rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :OperationalCondition ;
          rdfs:domain :Microorganism ;
          rdfs:range xsd:float ;
          rdfs:isDefinedBy "The concentration or presence of dissolved salts within a wastewater treatment system. Salinity influences the osmotic conditions of the treatment environment and affects microbial activity, process kinetics, biomass adaptation, substrate utilisation, corrosion potential, and the overall performance of biological and physicochemical wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SalinityMax
:SalinityMax rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :Salinity ;
             rdfs:domain :Microorganism ;
             rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SalinityMin
:SalinityMin rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :Salinity ;
             rdfs:domain :Microorganism ;
             rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#StoichiometricParameter
:StoichiometricParameter rdf:type owl:DatatypeProperty ;
                         rdfs:domain :Process ;
                         rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Temperature
:Temperature rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :OperationalCondition ;
             rdfs:domain :Microorganism ;
             rdfs:range xsd:float ;
             rdfs:isDefinedBy "A measure of the thermal condition of a wastewater treatment system or environment, typically expressed in degrees Celsius or Kelvin. Temperature influences microbial metabolism, enzyme activity, reaction kinetics, oxygen transfer, substrate utilisation, biomass growth, and overall treatment efficiency, making it a critical operational parameter in wastewater treatment and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#TemperatureMax
:TemperatureMax rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :Temperature ;
                rdfs:domain :Microorganism ;
                rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#TemperatureMin
:TemperatureMin rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :Temperature ;
                rdfs:domain :Microorganism ;
                rdfs:range xsd:float .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Unit
:Unit rdf:type owl:DatatypeProperty ;
      rdfs:domain :Parameters ;
      rdfs:range xsd:string ;
      rdfs:isDefinedBy "A standardised measurement reference used to express the magnitude, concentration, rate, or quantity of a parameter or component within a wastewater treatment system. Units provide consistency and comparability in process modelling, stoichiometric calculations, experimental analysis, operational monitoring, and engineering design by defining how variables such as mass, volume, concentration, time, and reaction rates are quantified." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Value
:Value rdf:type owl:DatatypeProperty ;
       rdfs:range xsd:float ;
       rdfs:isDefinedBy "A numerical or categorical quantity assigned to a parameter, component, or operational condition within a wastewater treatment system. Values are used to represent measured, estimated, or modelled data such as concentrations, reaction rates, kinetic coefficients, environmental conditions, and stoichiometric relationships, thereby supporting process monitoring, simulation, calibration, validation, and engineering analysis." .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcetoclasticMethanogen
:AcetoclasticMethanogen rdf:type owl:Class ;
                        rdfs:subClassOf :Methanogen .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcetoclasticSRB
:AcetoclasticSRB rdf:type owl:Class ;
                 rdfs:subClassOf :SulfateReducingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcetogenicSRB
:AcetogenicSRB rdf:type owl:Class ;
               rdfs:subClassOf :SulfateReducingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcidogenicBacteria
:AcidogenicBacteria rdf:type owl:Class ;
                    rdfs:subClassOf :HeterotrophicBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Algae
:Algae rdf:type owl:Class ;
       rdfs:subClassOf :Eukarya .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AmmoniaOxidizingBacteria
:AmmoniaOxidizingBacteria rdf:type owl:Class ;
                          rdfs:subClassOf :NitrifyingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Archaea
:Archaea rdf:type owl:Class ;
         rdfs:subClassOf :Microorganism ;
         rdfs:isDefinedBy "A domain of single-celled prokaryotic microorganisms that are genetically and metabolically distinct from bacteria. In wastewater treatment systems, archaea are particularly important in anaerobic processes such as methanogenesis, where methanogenic archaea convert substrates such as acetate, hydrogen, and carbon dioxide into methane during anaerobic digestion and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Bacteria
:Bacteria rdf:type owl:Class ;
          rdfs:subClassOf :Microorganism ;
          rdfs:isDefinedBy "A domain of single-celled prokaryotic microorganisms that play essential roles in biological wastewater treatment processes. Bacteria are responsible for the degradation and transformation of organic matter, nitrogen, phosphorus, sulfur compounds, and other contaminants through metabolic processes such as hydrolysis, fermentation, nitrification, denitrification, sulfate reduction, and enhanced biological phosphorus removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Bioreactor
:Bioreactor rdf:type owl:Class ;
            rdfs:isDefinedBy "A controlled treatment unit in which microorganisms perform biological reactions that transform, degrade, or remove contaminants from wastewater under defined environmental conditions such as aerobic, anoxic, or anaerobic conditions. Bioreactors provide the physical and chemical environment necessary for microbial growth, substrate utilisation, nutrient removal, and resource recovery processes in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#CarbonRemovalProcess
:CarbonRemovalProcess rdf:type owl:Class ;
                      rdfs:subClassOf :Process ;
                      owl:disjointWith :NitrogenRemovalProcess ,
                                       :PhosphorusRemovalProcess ,
                                       :SulfurRemovalProcess ;
                      rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, degradation, or removal of carbon-containing compounds from wastewater. Carbon removal processes primarily reduce biodegradable and non-biodegradable organic matter through biological, chemical, or physical mechanisms, contributing to improved effluent quality, reduced oxygen demand, and stabilisation of organic pollutants within treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Component
:Component rdf:type owl:Class ;
           rdfs:isDefinedBy "A chemical, biological, or physical entity represented within a wastewater treatment system or process model. Components may include dissolved substrates, particulate matter, microbial biomass, nutrients, gases, ions, and storage compounds that participate in biological, chemical, or physical transformations during wastewater treatment." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#DenitrifyingBacteria
:DenitrifyingBacteria rdf:type owl:Class ;
                      rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Eukarya
:Eukarya rdf:type owl:Class ;
         rdfs:subClassOf :Microorganism ;
         rdfs:isDefinedBy "A domain of organisms whose cells contain a membrane-bound nucleus and specialised organelles. In wastewater treatment systems, eukaryotic microorganisms such as protozoa, fungi, and algae contribute to processes including organic matter degradation, biomass stabilisation, nutrient uptake, pathogen control, and sludge floc formation within biological treatment environments." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#FilamentousBacteria
:FilamentousBacteria rdf:type owl:Class ;
                     rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Fungi
:Fungi rdf:type owl:Class ;
       rdfs:subClassOf :Eukarya .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Gas
:Gas rdf:type owl:Class ;
     rdfs:subClassOf :Component ;
     rdfs:isDefinedBy "A gaseous chemical component present, produced, or consumed within a wastewater treatment system. Gas components participate in biological and chemical transformations and may include compounds such as oxygen, carbon dioxide, methane, hydrogen sulfide, hydrogen, and nitrogen gas, which influence microbial activity, reactor performance, aeration requirements, greenhouse gas emissions, odor generation, and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#GlycogenAccumulatingOrganisms
:GlycogenAccumulatingOrganisms rdf:type owl:Class ;
                               rdfs:subClassOf :PhosphorusRemovingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HeterotrophicBacteria
:HeterotrophicBacteria rdf:type owl:Class ;
                       rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenotrophicMethanogen
:HydrogenotrophicMethanogen rdf:type owl:Class ;
                            rdfs:subClassOf :Methanogen .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenotrophicSRB
:HydrogenotrophicSRB rdf:type owl:Class ;
                     rdfs:subClassOf :SulfateReducingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#KineticParameter
:KineticParameter rdf:type owl:Class ;
                  rdfs:subClassOf :Parameters .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Methanogen
:Methanogen rdf:type owl:Class ;
            rdfs:subClassOf :Archaea .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Microorganism
:Microorganism rdf:type owl:Class ;
               rdfs:isDefinedBy "A living microbial organism or functional microbial group involved in biological transformations within wastewater treatment systems. Microorganisms drive essential treatment processes such as organic matter degradation, nitrification, denitrification, phosphorus removal, sulfate reduction, fermentation, and methanogenesis through their metabolic activities and interactions with environmental conditions and substrates." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MicroorganismBiomass
:MicroorganismBiomass rdf:type owl:Class ;
                      rdfs:subClassOf :Component ;
                      rdfs:isDefinedBy "A biological component representing living or active microbial matter within a wastewater treatment system. Biomass components consist of microorganisms and associated cellular material that drive biological treatment processes such as organic matter degradation, nutrient removal, sulfate reduction, fermentation, and methanogenesis through their metabolic activity and growth." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#NitrifyingBacteria
:NitrifyingBacteria rdf:type owl:Class ;
                    rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#NitriteOxidizingBacteria
:NitriteOxidizingBacteria rdf:type owl:Class ;
                          rdfs:subClassOf :NitrifyingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#NitrogenRemovalProcess
:NitrogenRemovalProcess rdf:type owl:Class ;
                        rdfs:subClassOf :Process ;
                        owl:disjointWith :PhosphorusRemovalProcess ,
                                         :SulfurRemovalProcess ;
                        rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, conversion, or removal of nitrogen-containing compounds from wastewater. Nitrogen removal processes reduce concentrations of compounds such as ammonium, nitrite, and nitrate through biological, chemical, or physical mechanisms, thereby preventing eutrophication, protecting aquatic ecosystems, and improving effluent quality in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OrdinaryHetetrophicBacteria
:OrdinaryHetetrophicBacteria rdf:type owl:Class ;
                             rdfs:subClassOf :HeterotrophicBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OxygenNiche
:OxygenNiche rdf:type owl:Class ;
             rdfs:isDefinedBy "The environmental condition or range of oxygen availability under which a microorganism or biological process can survive, grow, and function. Oxygen niches in wastewater treatment systems define whether microbial activity occurs under aerobic, anoxic, or anaerobic conditions, thereby influencing the distribution of microbial communities and the occurrence of processes such as nitrification, denitrification, fermentation, sulfate reduction, and methanogenesis." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Parameters
:Parameters rdf:type owl:Class ;
            rdfs:isDefinedBy "A parameter is a quantitative or qualitative variable used to describe, characterise, calibrate, or control wastewater treatment and resource recovery processes within a modelling or operational framework. Parameters may represent kinetic, stoichiometric, environmental, hydraulic, biochemical, or operational characteristics that influence microbial activity, substrate transformation, reaction rates, biomass growth, and overall process performance in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Particulate
:Particulate rdf:type owl:Class ;
             rdfs:subClassOf :Component ;
             rdfs:isDefinedBy "A component consisting of suspended or insoluble solid material present within a wastewater treatment system. Particulate components may include organic matter, microbial biomass, inert solids, precipitates, and particulate substrates that participate in sedimentation, hydrolysis, biological conversion, sludge formation, and solids handling processes during wastewater treatment." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PhosphateAccumulatingOrganisms
:PhosphateAccumulatingOrganisms rdf:type owl:Class ;
                                rdfs:subClassOf :PhosphorusRemovingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PhosphorusRemovalProcess
:PhosphorusRemovalProcess rdf:type owl:Class ;
                          rdfs:subClassOf :Process ;
                          owl:disjointWith :SulfurRemovalProcess ;
                          rdfs:isDefinedBy "A wastewater treatment process involved in the uptake, transformation, storage, or removal of phosphorus-containing compounds from wastewater. Phosphorus removal processes reduce phosphate concentrations through biological, chemical, or physical mechanisms, thereby preventing eutrophication, improving effluent quality, and supporting nutrient management and resource recovery within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PhosphorusRemovingBacteria
:PhosphorusRemovingBacteria rdf:type owl:Class ;
                            rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Process
:Process rdf:type owl:Class ;
         rdfs:isDefinedBy "A biological, chemical, or physical transformation or activity that occurs within a wastewater treatment system, resulting in the conversion, degradation, removal, or recovery of substances. Processes are driven by interactions between microorganisms, substrates, environmental conditions, and operational parameters, and collectively determine the performance and efficiency of wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Protozoa
:Protozoa rdf:type owl:Class ;
          rdfs:subClassOf :Eukarya .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Soluble
:Soluble rdf:type owl:Class ;
         rdfs:subClassOf :Component ;
         rdfs:isDefinedBy "A component that is dissolved within the liquid phase of a wastewater treatment system and is not present as suspended solids. Soluble components include dissolved substrates, nutrients, ions, gases, and metabolic products that are readily available for transport, microbial uptake, chemical reactions, and biological transformation processes during wastewater treatment." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#StoichiometricParameter
:StoichiometricParameter rdf:type owl:Class ;
                         rdfs:subClassOf :Parameters .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SulfateReducingBacteria
:SulfateReducingBacteria rdf:type owl:Class ;
                         rdfs:subClassOf :SulfateRemovingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SulfateRemovingBacteria
:SulfateRemovingBacteria rdf:type owl:Class ;
                         rdfs:subClassOf :Bacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SulfurOxidizingbacteria
:SulfurOxidizingbacteria rdf:type owl:Class ;
                         rdfs:subClassOf :SulfateRemovingBacteria .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#SulfurRemovalProcess
:SulfurRemovalProcess rdf:type owl:Class ;
                      rdfs:subClassOf :Process ;
                      rdfs:isDefinedBy "A wastewater treatment process involved in the transformation, oxidation, reduction, or removal of sulfur-containing compounds from wastewater. Sulfur removal processes regulate compounds such as sulfate and sulfide through biological, chemical, or physical mechanisms, contributing to odor control, corrosion prevention, toxicity reduction, nutrient cycling, and the recovery or stabilisation of sulfur compounds within wastewater treatment systems." .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AC_Biomass
:AC_Biomass rdf:type owl:NamedIndividual ,
                     :MicroorganismBiomass ;
            :EmpiricalFormula "CHYoOZoNAoPBo" ,
                              "X_ZAC" ;
            rdfs:isDefinedBy "A biomass component representing acetogenic microorganisms that convert fermentation products into acetate, hydrogen, and carbon dioxide under anaerobic conditions in wastewater treatment systems. Acetogenic biomass contributes to anaerobic digestion, carbon transformation, and the production of intermediates utilised in downstream processes such as methanogenesis and sulfate reduction." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#ADO_Biomass
:ADO_Biomass rdf:type owl:NamedIndividual ,
                      :MicroorganismBiomass ;
             :EmpiricalFormula "CHYoOZoNAoPBo" ;
             :GujerNotation "X_ADO" ;
             rdfs:isDefinedBy "A biomass component representing autotrophic denitrifying microorganisms that utilise inorganic electron donors such as sulfide or hydrogen to reduce nitrate or nitrite under anoxic conditions in wastewater treatment systems. ADO_Biomass contributes to nitrogen removal, sulfur transformation, and autotrophic nutrient removal processes in engineered treatment environments." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AM_Biomass
:AM_Biomass rdf:type owl:NamedIndividual ,
                     :MicroorganismBiomass ;
            :EmpiricalFormula "CHYoOZoNAoPBo" ;
            :GujerNotation "X_ZAM" ;
            rdfs:isDefinedBy "A biomass component representing acetoclastic methanogenic microorganisms that convert acetate into methane and carbon dioxide under anaerobic conditions in wastewater treatment systems. AM_Biomass contributes to anaerobic digestion, carbon stabilisation, biogas production, and energy recovery processes within anaerobic treatment environments." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#ANO_Biomass
:ANO_Biomass rdf:type owl:NamedIndividual ,
                      :MicroorganismBiomass ;
             :EmpiricalFormula "CHYoOZoNAoPBo" ;
             :GujerNotation "X_ANO" ;
             rdfs:isDefinedBy "A biomass component representing anaerobic heterotrophic microorganisms that degrade organic matter under anoxic or anaerobic conditions in wastewater treatment systems. ANO_Biomass contributes to processes such as denitrification, fermentation, and anaerobic carbon transformation through the utilisation of organic substrates in the absence of dissolved oxygen." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Acetate
:Acetate rdf:type owl:NamedIndividual ,
                  :Soluble ;
         :EmpiricalFormula "CH3COO-" ;
         :GujerNotation "S_VFA" ;
         rdfs:isDefinedBy "A soluble volatile fatty acid component commonly produced during the fermentation and acetogenesis of organic matter in wastewater treatment systems. Acetate serves as an important carbon source and electron donor for microorganisms involved in processes such as denitrification, sulfate reduction, and acetoclastic methanogenesis, thereby playing a central role in anaerobic digestion, carbon cycling, and biological nutrient removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Acetivibrio_clariflavus
:Acetivibrio_clariflavus rdf:type owl:NamedIndividual ,
                                  :AcetoclasticSRB ,
                                  :DenitrifyingBacteria ;
                         :hasOxygenNiche :Anaerobic ,
                                         :Anoxic ;
                         :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers ,
                                          :AutotrophicDenitrification ,
                                          :GrowthOfAcetoclasticSRB ,
                                          :LysisOfADO ;
                         :reduces :Nitrate ,
                                  :Sulphate ;
                         :BacDiveID 2853 ;
                         :OptimalPH "7.5"^^xsd:float ;
                         :OptimalTemperature "57.5"^^xsd:float ;
                         :PHMax "8.0"^^xsd:float ;
                         :PHMin "6.0"^^xsd:float ;
                         :SalinityMax "0.7"^^xsd:float ;
                         :SalinityMin "0.0"^^xsd:float ;
                         :TemperatureMax "65.0"^^xsd:float ;
                         :TemperatureMin "45.0"^^xsd:float ;
                         rdfs:isDefinedBy "Acetivibrio clariflavus is an anaerobic thermophilic microorganism capable of reducing sulfate and nitrate under oxygen-limited conditions. In this ontology, it is represented as a microorganism with defined environmental growth conditions and sulfur- and nitrogen-reduction capabilities relevant to wastewater microbial processes." ;
                         rdfs:label "Acetivibrio clariflavus" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Acetivibrio_saccincola
:Acetivibrio_saccincola rdf:type owl:NamedIndividual ,
                                 :AcetoclasticSRB ;
                        :hasOxygenNiche :Anaerobic ;
                        :reduces :Sulphate ;
                        :BacDiveID 132679 ;
                        :OptimalPH "7.0"^^xsd:float ;
                        :OptimalTemperature "60.0"^^xsd:float ;
                        :PHMax "9.0"^^xsd:float ;
                        :PHMin "6.5"^^xsd:float ;
                        :SalinityMax "0.2"^^xsd:float ;
                        :SalinityMin "0.0"^^xsd:float ;
                        :TemperatureMax "65.0"^^xsd:float ;
                        :TemperatureMin "45.0"^^xsd:float ;
                        rdfs:isDefinedBy "Acetivibrio saccincola is an anaerobic thermophilic microorganism associated with sulfate reduction under saline and oxygen-limited conditions. In this ontology, it is represented as a microorganism with environmental growth constraints and sulfur reduction capability." ;
                        rdfs:label "Acetivibrio saccincola" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcetoclasticMethanogenesis
:AcetoclasticMethanogenesis rdf:type owl:NamedIndividual ,
                                     :CarbonRemovalProcess ;
                            :consumesSubstrate :Ammonium ,
                                               :Phosphate ,
                                               :Sulphate ,
                                               :VolatileFattyAcids ,
                                               :Water ;
                            :hasKineticParameter :DecayRate_AM ,
                                                 :HalfSatCoeff_AM ,
                                                 :MaxGrowthRate_AM ;
                            :hasStoichiometricParameter :YieldCoeff_AM ;
                            :occursIn :AnaerobicBioreactor ;
                            :producesProduct :AM_Biomass ,
                                             :Carbonate ,
                                             :HydrogenIon ,
                                             :Methane ;
                            :usesElectronAcceptor :Carbonate ;
                            :usesElectronDonor :VolatileFattyAcids ;
                            rdfs:isDefinedBy """Acetoclastic methanogenesis is an anaerobic biological conversion process in which acetoclastic methanogenic microorganisms convert acetate-rich volatile fatty acids into methane (CH₄), carbon dioxide/carbonate species, and methanogenic biomass.

This process is one of the main methane-producing pathways during anaerobic digestion and plays a central role in energy recovery from wastewater organic matter. Acetate or acetate-rich volatile fatty acids function as the primary electron donor and carbon substrate, while carbon dioxide/carbonate species participate in the methanogenic redox balance. The process contributes to carbon removal, biogas generation, and stabilisation of organic matter under anaerobic conditions.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Acetogenesis
:Acetogenesis rdf:type owl:NamedIndividual ,
                       :CarbonRemovalProcess ;
              :consumesSubstrate :Ammonium ,
                                 :Phosphate ,
                                 :Propionate ,
                                 :Sulphate ,
                                 :Water ;
              :hasKineticParameter :DecayRate_AC ,
                                   :HalfSatCoeff_AC ,
                                   :MaxGrowthRate_AC ;
              :hasStoichiometricParameter :YieldCoeff_AC ;
              :occursIn :AnaerobicBioreactor ;
              :producesProduct :AC_Biomass ,
                               :Carbonate ,
                               :Hydrogen ,
                               :HydrogenIon ,
                               :VolatileFattyAcids ;
              :usesElectronAcceptor :HydrogenIon ;
              :usesElectronDonor :Propionate ;
              rdfs:isDefinedBy """Acetogenesis is an anaerobic biological conversion process in which acetogenic microorganisms transform intermediate fermentation products, particularly propionate and other soluble organic compounds, into acetate, hydrogen (H₂), and carbon dioxide/carbonate species. The process occurs under anaerobic conditions and represents a critical intermediate stage linking acidogenesis and methanogenesis during anaerobic digestion.

Acetogenic microorganisms use propionate and related organic substrates as electron donors while maintaining metabolic activity under low hydrogen partial pressure conditions to ensure thermodynamic feasibility. The products generated during acetogenesis serve as essential substrates for acetoclastic and hydrogenotrophic methanogenic microorganisms responsible for methane production. The process contributes to organic matter degradation, carbon transformation, and energy recovery within wastewater treatment systems and is governed by stoichiometric and kinetic parameters including maximum growth rate, decay rate, half-saturation coefficients, and biomass yield coefficients.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcidogenesisHighPH
:AcidogenesisHighPH rdf:type owl:NamedIndividual ,
                             :CarbonRemovalProcess ;
                    :consumesSubstrate :Ammonium ,
                                       :Glucose ,
                                       :Phosphate ,
                                       :Sulphate ,
                                       :Water ;
                    :hasKineticParameter :DecayRate_AD ,
                                         :HalfSatCoeff_AD ,
                                         :MaxGrowthRate_AD ;
                    :hasStoichiometricParameter :YieldCoeff_AH ;
                    :occursIn :AnaerobicBioreactor ;
                    :producesProduct :Carbonate ,
                                     :Hydrogen ,
                                     :HydrogenIon ,
                                     :Propionate ,
                                     :VolatileFattyAcids ;
                    :usesElectronDonor :Glucose ;
                    rdfs:isDefinedBy """Acidogenesis under high pH conditions is an anaerobic fermentative process in which acidogenic microorganisms transform soluble biodegradable organic matter into volatile fatty acids, propionate, hydrogen (H₂), carbon dioxide/carbonate species, and new microbial biomass.

The process is part of the anaerobic digestion pathway and provides essential intermediate products for acetogenic and methanogenic microorganisms. Organic substrates act as electron donors, while internal organic intermediates act as electron-accepting compounds during fermentation. This process contributes to organic carbon degradation, pH-dependent fermentation product distribution, and the preparation of substrates for methane-producing microbial communities.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AcidogenesisLowPH
:AcidogenesisLowPH rdf:type owl:NamedIndividual ,
                            :CarbonRemovalProcess ;
                   :consumesSubstrate :Ammonium ,
                                      :Glucose ,
                                      :Phosphate ,
                                      :Sulphate ,
                                      :Water ;
                   :hasKineticParameter :DecayRate_AD ,
                                        :HalfSatCoeff_AD ,
                                        :MaxGrowthRate_AD ;
                   :hasStoichiometricParameter :YieldCoeff_AD ;
                   :occursIn :AnaerobicBioreactor ;
                   :producesProduct :Acidogens_Biomass ,
                                    :Carbonate ,
                                    :Hydrogen ,
                                    :HydrogenIon ,
                                    :Propionate ,
                                    :VolatileFattyAcids ;
                   :usesElectronDonor :Glucose ;
                   rdfs:isDefinedBy """Acidogenesis under low pH conditions is an anaerobic fermentative process in which acidogenic microorganisms convert soluble biodegradable organic matter, such as sugars and other readily fermentable substrates, into volatile fatty acids, propionate, hydrogen (H₂), carbon dioxide/carbonate species, and acidogenic biomass.

This process forms an important stage in anaerobic digestion by transforming hydrolysis products into smaller organic intermediates that can be further converted during acetogenesis and methanogenesis. Acidogenic microorganisms use organic substrates as electron donors, while electron transfer occurs through internal organic intermediates because fermentation does not rely on an external terminal electron acceptor such as oxygen, nitrate, or sulfate. The process contributes to carbon transformation, organic matter degradation, and downstream methane production.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Acidogens_Biomass
:Acidogens_Biomass rdf:type owl:NamedIndividual ,
                            :MicroorganismBiomass ;
                   :EmpiricalFormula "CHYoOZoNAoPBo" ;
                   :GujerNotation "X_ZAD" ;
                   rdfs:isDefinedBy "A biomass component representing acidogenic microorganisms involved in the anaerobic conversion of complex organic matter into simpler soluble compounds such as volatile fatty acids, alcohols, hydrogen, and carbon dioxide during fermentation processes in wastewater treatment systems. Acidogenic biomass plays a key role in anaerobic digestion, carbon transformation, and the production of intermediates used in downstream microbial processes such as acetogenesis and methanogenesis." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Aerobic
:Aerobic rdf:type owl:NamedIndividual ,
                  :OxygenNiche ;
         owl:differentFrom :Anaerobic ,
                           :Anoxic ;
         rdfs:isDefinedBy "An environmental condition characterised by the presence of dissolved oxygen as the primary terminal electron acceptor for biological and chemical processes in wastewater treatment systems. Aerobic conditions support processes such as organic matter degradation, nitrification, and aerobic phosphorus removal by promoting the activity of oxygen-dependent microorganisms." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AerobicBioreactor
:AerobicBioreactor rdf:type owl:NamedIndividual ,
                            :Bioreactor ;
                   rdfs:isDefinedBy "A bioreactor operating under aerobic conditions in which dissolved oxygen is supplied to support the growth and metabolic activity of aerobic microorganisms in wastewater treatment systems. Aerobic bioreactors facilitate processes such as organic matter degradation, nitrification, and biological phosphorus removal through oxygen-dependent biological reactions and microbial transformations." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AerobicGrowthOfXaut
:AerobicGrowthOfXaut rdf:type owl:NamedIndividual ,
                              :NitrogenRemovalProcess ;
                     :consumesSubstrate :Ammonium ,
                                        :Carbonate ,
                                        :DissolvedOxygen ,
                                        :Magnesium ,
                                        :Phosphate ,
                                        :Sulphate ;
                     :occursIn :AerobicBioreactor ;
                     :producesProduct :ANO_Biomass ,
                                      :HydrogenIon ,
                                      :Nitrate ;
                     :usesElectronAcceptor :DissolvedOxygen ;
                     :usesElectronDonor :Ammonium ;
                     :isDefinedBy "Aerobic growth of autotrophic nitrifying biomass using ammonium as the electron donor and dissolved oxygen as the electron acceptor, producing nitrate and autotrophic biomass during biological nitrogen removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AerobicGrowthOfXpa
:AerobicGrowthOfXpa rdf:type owl:NamedIndividual ,
                             :PhosphorusRemovalProcess ;
                    :consumesSubstrate :Ammonium ,
                                       :Carbonate ,
                                       :DissolvedOxygen ,
                                       :Phosphate ,
                                       :Polyhydroxyalkanoate ;
                    :occursIn :AerobicBioreactor ;
                    :producesProduct :Carbonate ,
                                     :HydrogenIon ,
                                     :PAO_Biomass ;
                    :usesElectronAcceptor :DissolvedOxygen ;
                    :usesElectronDonor :Polyhydroxyalkanoate ;
                    :isDefinedBy "Aerobic growth of Xpa using stored polyhydroxyalkanoate as the internal carbon and energy source under aerobic conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AerobicOHOGrowthOnFSO
:AerobicOHOGrowthOnFSO rdf:type owl:NamedIndividual ,
                                :CarbonRemovalProcess ;
                       :consumesSubstrate :Ammonium ,
                                          :Carbonate ,
                                          :DissolvedOxygen ,
                                          :FermentableBiodegradableSolubleOrganics ,
                                          :Phosphate ;
                       :hasKineticParameter :DecayRate_OHO ,
                                            :MaxGrowthRate_OHO ;
                       :occursIn :AerobicBioreactor ;
                       :producesProduct :HydrogenIon ,
                                        :OHO_Biomass ;
                       :usesElectronAcceptor :DissolvedOxygen ;
                       :usesElectronDonor :FermentableBiodegradableSolubleOrganics ;
                       :isDefinedBy "Aerobic growth of ordinary heterotrophic organisms on fermentable soluble organics under aerobic conditions in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AerobicStorageOfPP
:AerobicStorageOfPP rdf:type owl:NamedIndividual ,
                             :PhosphorusRemovalProcess ;
                    :consumesSubstrate :Calcium ,
                                       :DissolvedOxygen ,
                                       :HydrogenIon ,
                                       :Magnesium ,
                                       :Phosphate ,
                                       :Polyhydroxyalkanoate ,
                                       :Potassium ;
                    :occursIn :AerobicBioreactor ;
                    :producesProduct :Carbonate ,
                                     :HydrogenIon ,
                                     :Polyphosphate ,
                                     :Water ;
                    :usesElectronAcceptor :DissolvedOxygen ;
                    :usesElectronDonor :Polyhydroxyalkanoate ;
                    :isDefinedBy "Aerobic storage of intracellular polyphosphate by Xpa using stored polyhydroxyalkanoate under aerobic conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Ammonium
:Ammonium rdf:type owl:NamedIndividual ,
                   :Soluble ;
          :EmpiricalFormula "NH4+" ;
          :GujerNotation "S_NHx" ;
          rdfs:isDefinedBy "A soluble inorganic nitrogen component present in wastewater treatment systems, typically in the form of ammonia or ammonium ions. Ammonium serves as a key nitrogen substrate for biological processes such as nitrification, assimilation, and anaerobic ammonium oxidation, and plays an important role in nutrient cycling, microbial metabolism, and nitrogen removal within wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Anaerobic
:Anaerobic rdf:type owl:NamedIndividual ,
                    :OxygenNiche ;
           owl:differentFrom :Anoxic ;
           rdfs:isDefinedBy "An environmental condition characterised by the absence of dissolved oxygen and alternative oxidised electron acceptors such as nitrate and nitrite in wastewater treatment systems. Anaerobic conditions support processes such as fermentation, acetogenesis, sulfate reduction, and methanogenesis through the activity of anaerobic microorganisms involved in organic matter degradation, nutrient transformation, and biogas production." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AnaerobicBioreactor
:AnaerobicBioreactor rdf:type owl:NamedIndividual ,
                              :Bioreactor ;
                     rdfs:isDefinedBy "A bioreactor operating under anaerobic conditions in which dissolved oxygen and alternative oxidised electron acceptors are absent, allowing anaerobic microorganisms to carry out biological processes such as fermentation, acetogenesis, sulfate reduction, and methanogenesis in wastewater treatment systems. Anaerobic bioreactors support organic matter stabilisation, nutrient transformation, sludge reduction, biogas production, and energy recovery through anaerobic microbial activity." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Anaeromicrobium_sediminis
:Anaeromicrobium_sediminis rdf:type owl:NamedIndividual ,
                                    :DenitrifyingBacteria ,
                                    :HydrogenotrophicSRB ;
                           :hasOxygenNiche :Anaerobic ,
                                           :Anoxic ;
                           :performsProcess :AnoxicGrowthOfAutotrophicDenitrifiers ,
                                            :AutotrophicDenitrification ,
                                            :DeathAndDecayOfHydrogenotrophicSRB ,
                                            :GrowthOfHydrogenotrophicSRB ,
                                            :LysisOfADO ;
                           :reduces :ElementalSulfur ,
                                    :Nitrate ,
                                    :Sulfite ,
                                    :Sulphate ,
                                    :Thiosulfate ;
                           :BacDiveID 140570 ;
                           :OptimalPH "7.5"^^xsd:float ;
                           :OptimalTemperature "37.0"^^xsd:float ;
                           :PHMax "9.0"^^xsd:float ;
                           :PHMin "6.5"^^xsd:float ;
                           :SalinityMax "30.0"^^xsd:float ;
                           :SalinityMin "10.0"^^xsd:float ;
                           :TemperatureMax "40.0"^^xsd:float ;
                           :TemperatureMin "25.0"^^xsd:float ;
                           rdfs:isDefinedBy "Anaeromicrobium sediminis is an anaerobic microorganism capable of reducing sulfate, elemental sulfur, sulfite, thiosulfate, and nitrate. In this ontology, it is represented as a sulfur- and nitrogen-transforming microorganism associated with saline anaerobic environments and wastewater sulfur cycling." ;
                           rdfs:label "Anaeromicrobium sediminis" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Anaerosacchariphilus_polymeriproducens
:Anaerosacchariphilus_polymeriproducens rdf:type owl:NamedIndividual ,
                                                 :AcetogenicSRB ,
                                                 :DenitrifyingBacteria ;
                                        :hasOxygenNiche :Anaerobic ;
                                        :performsProcess :GrowthOfAcetogenicSRBBiomass ;
                                        :reduces :Nitrate ,
                                                 :Nitrite ,
                                                 :Thiosulfate ;
                                        :BacDiveID 166544 ;
                                        :OptimalPH "7.0"^^xsd:float ;
                                        :OptimalTemperature "37.0"^^xsd:float ;
                                        :PHMax "10.0"^^xsd:float ;
                                        :PHMin "5.5"^^xsd:float ;
                                        :SalinityMax "6.0"^^xsd:float ;
                                        :SalinityMin "0.0"^^xsd:float ;
                                        :TemperatureMax "42.0"^^xsd:float ;
                                        :TemperatureMin "20.0"^^xsd:float ;
                                        rdfs:isDefinedBy "Anaerosacchariphilus polymeriproducens is an anaerobic microorganism capable of reducing thiosulfate, nitrate, and nitrite. In this ontology, it is represented as a microorganism involved in sulfur and nitrogen transformation processes under anaerobic conditions." ;
                                        rdfs:label "Anaerosacchariphilus polymeriproducens" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Anaerosporomusa_subterranea
:Anaerosporomusa_subterranea rdf:type owl:NamedIndividual ,
                                      :AcetogenicSRB ;
                             :hasOxygenNiche :Anaerobic ;
                             :reduces :Sulphate ;
                             :BacDiveID 132639 ;
                             :OptimalPH "6.8"^^xsd:float ;
                             :OptimalTemperature "28.0"^^xsd:float ;
                             :PHMax "7.5"^^xsd:float ;
                             :PHMin "5.0"^^xsd:float ;
                             :TemperatureMax "30.0"^^xsd:float ;
                             :TemperatureMin "24.0"^^xsd:float ;
                             rdfs:isDefinedBy "Anaerosporomusa subterranea is an anaerobic microorganism associated with sulfate reduction under mesophilic conditions. In this ontology, it is represented as a sulfur-reducing microorganism relevant to anaerobic wastewater environments." ;
                             rdfs:label "Anaerosporomusa subterranea" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Andreessenia_angusta
:Andreessenia_angusta rdf:type owl:NamedIndividual ,
                               :AcetogenicSRB ,
                               :DenitrifyingBacteria ;
                      :hasOxygenNiche :Anaerobic ;
                      :reduces :Nitrate ,
                               :Sulphate ;
                      :BacDiveID 5416 ;
                      :OptimalPH "7.5"^^xsd:float ;
                      :OptimalTemperature "37.0"^^xsd:float ;
                      :PHMax "10.0"^^xsd:float ;
                      :PHMin "6.5"^^xsd:float ;
                      :TemperatureMax "45.0"^^xsd:float ;
                      :TemperatureMin "18.0"^^xsd:float ;
                      rdfs:isDefinedBy "Andreessenia angusta is an anaerobic microorganism capable of sulfate and nitrate reduction under variable environmental conditions. In this ontology, it is represented as a microorganism associated with sulfur and nitrogen transformation pathways relevant to wastewater treatment systems." ;
                      rdfs:label "Andreessenia angusta" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Anoxic
:Anoxic rdf:type owl:NamedIndividual ,
                 :OxygenNiche ;
        rdfs:isDefinedBy "An environmental condition characterised by the absence of dissolved oxygen but the presence of alternative electron acceptors such as nitrate or nitrite in wastewater treatment systems. Anoxic conditions support biological processes such as denitrification and autotrophic denitrification, where microorganisms utilise oxidised nitrogen compounds instead of oxygen for energy generation and nutrient removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AnoxicBioreactor
:AnoxicBioreactor rdf:type owl:NamedIndividual ,
                           :Bioreactor ;
                  rdfs:isDefinedBy "A bioreactor operating under anoxic conditions in which dissolved oxygen is absent but alternative electron acceptors such as nitrate or nitrite are available for microbial metabolism in wastewater treatment systems. Anoxic bioreactors support processes such as denitrification and autotrophic denitrification, contributing to nitrogen removal, nutrient transformation, and biological wastewater treatment under oxygen-limited conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AnoxicGrowthOfAutotrophicDenitrifiers
:AnoxicGrowthOfAutotrophicDenitrifiers rdf:type owl:NamedIndividual ,
                                                :NitrogenRemovalProcess ;
                                       :consumesSubstrate :Ammonium ,
                                                          :Carbonate ,
                                                          :HydrogenSulfide ,
                                                          :Nitrate ,
                                                          :Phosphate ;
                                       :hasKineticParameter :DecayRate_ADO ,
                                                            :MaxGrowthRate_ADO ;
                                       :occursIn :AnoxicBioreactor ;
                                       :producesProduct :ADO_Biomass ,
                                                        :HydrogenIon ,
                                                        :NitrogenGas ,
                                                        :Sulphate ;
                                       :usesElectronAcceptor :Nitrate ;
                                       :usesElectronDonor :HydrogenSulfide ;
                                       :isDefinedBy "Anoxic growth of autotrophic denitrifying microorganisms using hydrogen sulfide as the electron donor and nitrate as the electron acceptor, resulting in sulfate production, nitrogen removal, and autotrophic biomass growth in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AnoxicOHOGrowthOnAcetate
:AnoxicOHOGrowthOnAcetate rdf:type owl:NamedIndividual ,
                                   :NitrogenRemovalProcess ;
                          :consumesSubstrate :Acetate ,
                                             :Ammonium ,
                                             :Carbonate ,
                                             :Nitrate ,
                                             :Phosphate ;
                          :hasKineticParameter :DecayRate_OHO ,
                                               :MaxGrowthRate_OHO ;
                          :occursIn :AnoxicBioreactor ;
                          :producesProduct :HydrogenIon ,
                                           :NitrogenGas ,
                                           :OHO_Biomass ;
                          :usesElectronAcceptor :Nitrate ;
                          :usesElectronDonor :Acetate ;
                          :isDefinedBy "Anoxic growth of ordinary heterotrophic organisms on acetate coupled with nitrate reduction during biological nitrogen removal processes in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AnoxicOHOGrowthOnFSO
:AnoxicOHOGrowthOnFSO rdf:type owl:NamedIndividual ,
                               :NitrogenRemovalProcess ;
                      :consumesSubstrate :Ammonium ,
                                         :Carbonate ,
                                         :FermentableBiodegradableSolubleOrganics ,
                                         :Nitrate ,
                                         :Phosphate ;
                      :hasKineticParameter :DecayRate_OHO ,
                                           :MaxGrowthRate_OHO ;
                      :occursIn :AnoxicBioreactor ;
                      :producesProduct :HydrogenIon ,
                                       :NitrogenGas ,
                                       :OHO_Biomass ;
                      :usesElectronAcceptor :Nitrate ;
                      :usesElectronDonor :FermentableBiodegradableSolubleOrganics ;
                      :isDefinedBy "Anoxic growth of ordinary heterotrophic organisms on fermentable soluble organics coupled with nitrate reduction during biological nitrogen removal processes in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AutotrophicDenitrification
:AutotrophicDenitrification rdf:type owl:NamedIndividual ,
                                     :NitrogenRemovalProcess ;
                            :consumesSubstrate :Carbonate ,
                                               :HydrogenIon ,
                                               :Phosphate ;
                            :hasKineticParameter :DecayRate_ADO ,
                                                 :MaxGrowthRate_ADO ;
                            :hasStoichiometricParameter :YieldCoeff_ADO ;
                            :occursIn :AnoxicBioreactor ;
                            :producesProduct :NitrogenGas ,
                                             :Sulphate ,
                                             :Water ;
                            :usesElectronAcceptor :Nitrate ;
                            :usesElectronDonor :HydrogenSulfide ;
                            rdfs:isDefinedBy """Autotrophic denitrification is an anoxic biological nitrogen removal process in which autotrophic denitrifying microorganisms (X_ADO) reduce nitrate (NO3−) and/or nitrite (NO2−) to nitrogen gas (N₂) using inorganic reduced sulfur compounds, such as sulfide (H₂S), elemental sulfur (S⁰), or thiosulfate (S₂O₃²−), as electron donors. The process occurs under anoxic conditions where dissolved oxygen is absent and nitrate or nitrite serves as the terminal electron acceptor. 

During autotrophic denitrification, inorganic carbon sources such as carbonate or bicarbonate are utilized for autotrophic biomass growth. The process contributes to simultaneous nitrogen removal and sulfur oxidation within wastewater treatment systems, producing sulfate (SO₄²−), nitrogen gas, water, protons, and autotrophic denitrifying biomass. Autotrophic denitrification is particularly important in saline and sulfur-rich wastewater treatment systems, including SANI-based processes, due to its lower organic carbon requirement and reduced sludge production compared to heterotrophic denitrification. The process is governed by stoichiometric and kinetic parameters including growth rates, decay rates, half-saturation coefficients, inhibition coefficients, and biomass yield coefficients.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#AutotrophicNitrification
:AutotrophicNitrification rdf:type owl:NamedIndividual ,
                                   :NitrogenRemovalProcess ;
                          :consumesSubstrate :Carbonate ,
                                             :Phosphate ,
                                             :Sulphate ;
                          :hasKineticParameter :DecayRate_ANO ,
                                               :MaxGrowthRate_ANO ;
                          :occursIn :AerobicBioreactor ;
                          :producesProduct :ANO_Biomass ,
                                           :HydrogenIon ,
                                           :Nitrate ,
                                           :Water ;
                          :usesElectronAcceptor :DissolvedOxygen ;
                          :usesElectronDonor :Ammonium ;
                          rdfs:isDefinedBy """Nitrification is an aerobic biological nitrogen removal process in which autotrophic nitrifying microorganisms (X_ANO) oxidize ammonium (NH4+) to nitrate (NO3−) using dissolved oxygen (O2) as the terminal electron acceptor. The process occurs within aerobic bioreactors and contributes to nitrogen conversion, alkalinity consumption, proton (H+) production, and biomass growth. 

During nitrification, ammonium serves as the electron donor while oxygen supports energy generation for autotrophic growth. The process produces nitrate, water, hydrogen ions, and autotrophic nitrifying biomass, and is governed by stoichiometric and kinetic parameters including growth rates, decay rates, half-saturation coefficients, and biomass yield coefficients. Nitrification plays a critical role in wastewater treatment systems by reducing ammonia toxicity, enabling downstream denitrification, and maintaining effluent nitrogen compliance.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#BiodegradableParticulateOrganics
:BiodegradableParticulateOrganics rdf:type owl:NamedIndividual ,
                                           :Particulate ;
                                  :EmpiricalFormula "CHYbpOzbpNAbpPBbp" ;
                                  :GujerNotation "X_B_Org" ;
                                  rdfs:isDefinedBy "A particulate organic component consisting of biodegradable suspended organic matter present in wastewater treatment systems. Biodegradable particulate organics serve as a substrate for microbial degradation processes such as hydrolysis, fermentation, aerobic oxidation, and anaerobic digestion, contributing to carbon removal, biomass growth, nutrient transformation, and energy recovery within wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Calcite
:Calcite rdf:type owl:NamedIndividual ,
                  :Particulate ;
         :EmpiricalFormula "CaCO3" ;
         :GujerNotation "X_Cal" ;
         rdfs:isDefinedBy "A mineral calcium carbonate component that may form, dissolve, or precipitate within wastewater treatment systems under specific chemical and environmental conditions. Calcite plays an important role in alkalinity balance, phosphorus precipitation, scaling, mineral formation, and inorganic carbon transformations in wastewater treatment and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#CalciteDissolution
:CalciteDissolution rdf:type owl:NamedIndividual ,
                             :CarbonRemovalProcess ;
                    :consumesSubstrate :Calcite ;
                    :occursIn :AnaerobicBioreactor ;
                    :producesProduct :Calcium ,
                                     :Carbonate ;
                    :isDefinedBy "Dissolution of calcite resulting in the release of calcium and carbonate into solution within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Calcium
:Calcium rdf:type owl:NamedIndividual ,
                  :Soluble ;
         :EmpiricalFormula "Ca2+" ;
         :GujerNotation "S_Ca" ;
         rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and natural waters. Calcium participates in chemical precipitation, mineral formation, alkalinity balance, floc formation, and phosphorus removal processes, and contributes to the formation of compounds such as calcite and calcium phosphate under specific environmental and operational conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#CalciumPhosphate
:CalciumPhosphate rdf:type owl:NamedIndividual ,
                           :Particulate ;
                  :EmpiricalFormula "Ca3(PO4)2" ,
                                    "X_ACP" ;
                  rdfs:isDefinedBy "A mineral component consisting of calcium and phosphate compounds that may form through chemical or biological precipitation processes in wastewater treatment systems. Calcium phosphate plays an important role in phosphorus removal, nutrient recovery, sludge composition, scaling, and mineral formation under specific chemical and environmental conditions within wastewater treatment and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#CarbonDioxide
:CarbonDioxide rdf:type owl:NamedIndividual ,
                        :Gas ;
               :EmpiricalFormula "CO2" ;
               :GujerNotation "G_CO2" ;
               rdfs:isDefinedBy "A gaseous inorganic carbon component produced and consumed during biological, chemical, and physicochemical processes in wastewater treatment systems. Carbon dioxide is generated through processes such as aerobic respiration, fermentation, acetogenesis, and methanogenesis, and contributes to carbon cycling, alkalinity balance, pH regulation, gas emissions, and microbial metabolism within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Carbonate
:Carbonate rdf:type owl:NamedIndividual ,
                    :Soluble ;
           :EmpiricalFormula "CO32-" ;
           :GujerNotation "S_CO3" ;
           rdfs:isDefinedBy "A dissolved inorganic carbon component present in wastewater treatment systems, primarily in the form of carbonate and bicarbonate ions. Carbonate contributes to alkalinity, pH buffering, inorganic carbon availability, mineral precipitation, and chemical equilibrium processes, and plays an important role in biological treatment, nitrification, anaerobic digestion, and carbonate mineral formation within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Chloride
:Chloride rdf:type owl:NamedIndividual ,
                   :Soluble ;
          :EmpiricalFormula "Cl-" ;
          :GujerNotation "S_Cl" ;
          rdfs:isDefinedBy "A dissolved inorganic anion component commonly present in wastewater treatment systems and saline wastewaters. Chloride contributes to salinity, ionic strength, osmotic conditions, conductivity, and corrosion potential, and may influence microbial activity, process performance, and the operation of biological and physicochemical wastewater treatment processes under saline conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#DeathAndDecayOfAcetateDegraders
