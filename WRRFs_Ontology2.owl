###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Hydrogen
:Hydrogen rdf:type owl:NamedIndividual ,
                   :Soluble ;
          :EmpiricalFormula "H2" ;
          :GujerNotation "S_H2" ;
          rdfs:isDefinedBy "A dissolved gaseous component that serves as an important electron donor and intermediate compound in anaerobic wastewater treatment systems. Hydrogen is produced during fermentation and acetogenesis and is utilised by microorganisms in processes such as hydrogenotrophic methanogenesis, sulfate reduction, and autotrophic denitrification, thereby contributing to carbon transformation, energy transfer, biogas production, and microbial metabolic interactions within wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenIon
:HydrogenIon rdf:type owl:NamedIndividual ,
                      :Soluble ;
             :EmpiricalFormula "H+" ;
             :GujerNotation "S_H" ;
             rdfs:isDefinedBy "A dissolved chemical component representing hydrogen ions in aqueous solution within wastewater treatment systems. Hydrogen ions determine the acidity or alkalinity of the treatment environment and play a critical role in pH regulation, chemical equilibria, microbial activity, reaction kinetics, nutrient availability, and overall process stability during biological and physicochemical wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenSulfide
:HydrogenSulfide rdf:type owl:NamedIndividual ,
                          :Soluble ;
                 :EmpiricalFormula "HS-" ;
                 :GujerNotation "S_HS" ;
                 rdfs:isDefinedBy "A dissolved reduced sulfur component produced during sulfate reduction and anaerobic degradation processes in wastewater treatment systems. Hydrogen sulfide acts as an electron donor in sulfur oxidation and autotrophic denitrification processes, while also contributing to odor generation, toxicity, corrosion, gas emissions, and sulfur cycling within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenotrophicMethanogenesis
:HydrogenotrophicMethanogenesis rdf:type owl:NamedIndividual ,
                                         :CarbonRemovalProcess ;
                                :consumesSubstrate :Ammonium ,
                                                   :Carbonate ,
                                                   :Hydrogen ,
                                                   :HydrogenIon ,
                                                   :Phosphate ,
                                                   :Sulphate ;
                                :hasKineticParameter :DecayRate_HM ,
                                                     :HalfSatCoeff_HM ,
                                                     :MaxGrowthRate_HM ;
                                :hasStoichiometricParameter :YieldCoeff_HM ;
                                :occursIn :AnaerobicBioreactor ;
                                :producesProduct :Methane ,
                                                 :Water ;
                                :usesElectronAcceptor :Carbonate ;
                                :usesElectronDonor :Hydrogen ;
                                rdfs:isDefinedBy """Hydrogenotrophic methanogenesis is an anaerobic biological conversion process in which hydrogenotrophic methanogenic microorganisms use hydrogen (H₂) as an electron donor and carbon dioxide/carbonate species as electron acceptors to produce methane (CH₄), water, and methanogenic biomass.

This process is important in anaerobic digestion because it consumes hydrogen produced during fermentation and acetogenesis, helping to maintain low hydrogen partial pressure and supporting the thermodynamic feasibility of upstream anaerobic reactions. Hydrogenotrophic methanogenesis contributes to carbon transformation, methane production, biogas formation, and energy recovery in wastewater treatment systems.""" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrolysisOfBPO
