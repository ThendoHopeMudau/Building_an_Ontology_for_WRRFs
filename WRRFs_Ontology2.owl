###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#HydrogenotrophicMethanogenesis
:HydrogenotrophicMethanogenesis rdf:type owl:NamedIndividual ,
                                         :CarbonRemovalProcess ;
                                :consumesSubstrate :Ammonium ,
                                                   :Carbonate ,
                                                   :Hydrogen ,
                                                   :HydrogenIon ,
                                                   :Phosphate ,
                                                   :Sulphate ;
                                :hasKineticParameter :DecayRate_HM ,
                                                     :HalfSatCoeff_HM ,
                                                     :MaxGrowthRate_HM ;
                                :hasStoichiometricParameter :YieldCoeff_HM ;
                                :occursIn :AnaerobicBioreactor ;
                                :producesProduct :Methane ,
                                                 :Water ;
                                :usesElectronAcceptor :Carbonate ;
                                :usesElectronDonor :Hydrogen ;
                                rdfs:isDefinedBy """Hydrogenotrophic methanogenesis is an anaerobic biological conversion process in which hydrogenotrophic methanogenic microorganisms use hydrogen (H₂) as an electron donor and carbon dioxide/carbonate species as electron acceptors to produce methane (CH₄), water, and methanogenic biomass.

This process is important in anaerobic digestion because it consumes hydrogen produced during fermentation and acetogenesis, helping to maintain low hydrogen partial pressure and supporting the thermodynamic feasibility of upstream anaerobic reactions. Hydrogenotrophic methanogenesis contributes to carbon transformation, methane production, biogas formation, and energy recovery in wastewater treatment systems.""" .


