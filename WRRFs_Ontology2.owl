###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Magnesite
:Magnesite rdf:type owl:NamedIndividual ,
                    :Particulate ;
           :EmpiricalFormula "MgCO3" ;
           :GujerNotation "X_Mag" ;
           rdfs:isDefinedBy "A mineral carbonate component primarily composed of magnesium carbonate that may form, dissolve, or precipitate within wastewater treatment systems under specific chemical and environmental conditions. Magnesite contributes to inorganic carbon transformations, alkalinity balance, mineral precipitation, scaling, and magnesium-related nutrient recovery processes within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MagnesiteDissolution
:MagnesiteDissolution rdf:type owl:NamedIndividual ,
                               :CarbonRemovalProcess ;
                      :consumesSubstrate :Magnesite ;
                      :occursIn :AnaerobicBioreactor ;
                      :producesProduct :Carbonate ,
                                       :Magnesium ;
                      :isDefinedBy "Dissolution of magnesite resulting in the release of magnesium and carbonate into solution within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Magnesium
:Magnesium rdf:type owl:NamedIndividual ,
                    :Soluble ;
           :EmpiricalFormula "Mg2+" ;
           :GujerNotation "S_Mg" ;
           rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and natural waters. Magnesium participates in biological and chemical processes including mineral precipitation, struvite formation, phosphorus recovery, alkalinity balance, floc formation, and nutrient removal, and plays an important role in wastewater treatment, sludge processing, and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_AC
:MaxGrowthRate_AC rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_AC" ;
                  :Unit "1/d" ;
                  :Value "1.15"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for acetogenic microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_ACS
:MaxGrowthRate_ACS rdf:type owl:NamedIndividual ,
                            :KineticParameter ;
                   :GujerNotation "mu_ACS" ;
                   :Unit "1/d" ;
                   :Value "0.583"^^xsd:float ;
                   rdfs:isDefinedBy "Maximum specific growth rate for acetogenic sulfate-reducing microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_AD
:MaxGrowthRate_AD rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_AD" ;
                  :Unit "1/d" ;
                  :Value "0.8"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for acidogenic microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_ADO
:MaxGrowthRate_ADO rdf:type owl:NamedIndividual ,
                            :KineticParameter ;
                   :GujerNotation "mu_ADO" ;
                   :Unit "1/d" ;
                   :Value "1.0"^^xsd:float ;
                   rdfs:isDefinedBy "Maximum specific growth rate for autotrophic denitrifying microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_AM
:MaxGrowthRate_AM rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_AM" ;
                  :Unit "1/d" ;
                  :Value "4.39"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for acetoclastic methanogenic microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_ANO
:MaxGrowthRate_ANO rdf:type owl:NamedIndividual ,
                            :KineticParameter ;
                   :GujerNotation "mu_ANO" ;
                   :Unit "1/d" ;
                   :Value "1.0"^^xsd:float ;
                   rdfs:isDefinedBy "Maximum specific growth rate for autotrophic nitrifying microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_AS
:MaxGrowthRate_AS rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_AS" ;
                  :Unit "1/d" ;
                  :Value "0.612"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for acetoclastic sulfate-reducing microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_HM
:MaxGrowthRate_HM rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_HM" ;
                  :Unit "1/d" ;
                  :Value "1.2"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for hydrogenotrophic methanogenic microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_HS
:MaxGrowthRate_HS rdf:type owl:NamedIndividual ,
                           :KineticParameter ;
                  :GujerNotation "mu_HS" ;
                  :Unit "1/d" ;
                  :Value "2.8"^^xsd:float ;
                  rdfs:isDefinedBy "Maximum specific growth rate for hydrogenotrophic sulfate-reducing microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_OHO
:MaxGrowthRate_OHO rdf:type owl:NamedIndividual ,
                            :KineticParameter ;
                   :GujerNotation "mu_OHO_max" ;
                   :Unit "1/d" ;
                   :Value "6.0"^^xsd:float ;
                   rdfs:isDefinedBy "Maximum specific growth rate for ordinary heterotrophic microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MaxGrowthRate_PAO
:MaxGrowthRate_PAO rdf:type owl:NamedIndividual ,
                            :KineticParameter ;
                   :GujerNotation "mu_PAO" ;
                   :Unit "1/d" ;
                   :Value "1.0"^^xsd:float ;
                   rdfs:isDefinedBy "Maximum specific growth rate for phosphorus accumulating microorganisms" .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Methane
:Methane rdf:type owl:NamedIndividual ,
                  :Gas ;
         :EmpiricalFormula "CH4" ;
         :GujerNotation "G_CH4" ;
         rdfs:isDefinedBy "A gaseous hydrocarbon component produced primarily during anaerobic biological processes in wastewater treatment systems. Methane is generated by methanogenic microorganisms during the conversion of acetate, hydrogen, and carbon dioxide in anaerobic digestion processes, contributing to carbon stabilisation, biogas production, renewable energy recovery, and greenhouse gas emissions within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#MgKP_Dissolution
:MgKP_Dissolution rdf:type owl:NamedIndividual ,
                           :PhosphorusRemovalProcess ;
                  :occursIn :AnaerobicBioreactor ;
                  :producesProduct :Magnesium ,
                                   :Phosphate ,
                                   :Potassium ;
                  :isDefinedBy "Dissolution of potassium struvite resulting in the release of potassium, magnesium, and phosphate into solution." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Newberyite
:Newberyite rdf:type owl:NamedIndividual ,
                     :Particulate ;
            :EmpiricalFormula "MgHPO4" ;
            :GujerNotation "X_Newb" ;
            rdfs:isDefinedBy "A mineral phosphate component primarily composed of magnesium phosphate compounds that may form through precipitation processes in wastewater treatment systems. Newberyite is associated with phosphorus recovery, nutrient precipitation, mineral formation, scaling, and sludge chemistry under specific chemical and operational conditions within wastewater treatment and resource recovery processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#NewberyiteDissolution
:NewberyiteDissolution rdf:type owl:NamedIndividual ,
                                :PhosphorusRemovalProcess ;
                       :consumesSubstrate :HydrogenIon ,
                                          :Newberyite ;
                       :occursIn :AnaerobicBioreactor ;
                       :producesProduct :Magnesium ,
                                        :Phosphate ;
                       :isDefinedBy "Dissolution of newberyite resulting in the release of magnesium and phosphate into solution during phosphorus transformation and mineral dissolution processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Nitrate
:Nitrate rdf:type owl:NamedIndividual ,
                  :Soluble ;
         :EmpiricalFormula "NO3-" ;
         :GujerNotation "S_NOx" ;
         rdfs:isDefinedBy "A dissolved inorganic nitrogen component present in wastewater treatment systems and commonly formed during nitrification processes. Nitrate serves as an alternative terminal electron acceptor for microorganisms under anoxic conditions and plays a central role in biological nitrogen removal processes such as denitrification and autotrophic denitrification, contributing to nutrient transformation, nitrogen cycling, and effluent quality improvement within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Nitrite
:Nitrite rdf:type owl:NamedIndividual ,
                  :Soluble ;
         :EmpiricalFormula "NO2-" ;
         :GujerNotation "S_NO2" ;
         rdfs:isDefinedBy "Nitrite is a soluble inorganic nitrogen component that occurs as an intermediate in nitrification and denitrification. In wastewater treatment systems, nitrite can serve as an electron acceptor during anoxic microbial metabolism and is important in biological nitrogen removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#NitrogenGas
:NitrogenGas rdf:type owl:NamedIndividual ,
                      :Soluble ;
             :EmpiricalFormula "N2" ;
             :GujerNotation "S_N2" ;
             rdfs:isDefinedBy "A gaseous nitrogen component produced during biological nitrogen removal processes in wastewater treatment systems. Nitrogen gas is primarily generated through denitrification and anaerobic ammonium oxidation processes, where oxidised nitrogen compounds such as nitrate and nitrite are converted into inert gaseous nitrogen, contributing to nitrogen removal, nutrient cycling, and effluent quality improvement within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#OHO_Biomass
:OHO_Biomass rdf:type owl:NamedIndividual ,
                      :MicroorganismBiomass ;
             :EmpiricalFormula "CHYoOZoNAoPBo" ,
                               "X_OHO" ;
             rdfs:isDefinedBy "A biomass component representing ordinary heterotrophic organisms that utilise biodegradable organic matter as a carbon and energy source in wastewater treatment systems. OHO_Biomass contributes to processes such as aerobic organic matter degradation, denitrification, substrate conversion, and biomass growth, playing a major role in carbon removal and biological wastewater treatment performance." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PAO_Biomass
:PAO_Biomass rdf:type owl:NamedIndividual ,
                      :MicroorganismBiomass ;
             :EmpiricalFormula "CHYoOZoNAoPBo" ;
             :GujerNotation "X_PAO" ;
             rdfs:isDefinedBy "A biomass component representing phosphate-accumulating organisms that are capable of taking up, storing, and cycling phosphorus within wastewater treatment systems. PAO_Biomass plays a central role in enhanced biological phosphorus removal processes by accumulating intracellular polyphosphate under alternating anaerobic and aerobic or anoxic conditions, thereby contributing to phosphorus removal, nutrient recovery, and wastewater treatment efficiency." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PPRelease
:PPRelease rdf:type owl:NamedIndividual ,
                    :PhosphorusRemovalProcess ;
           :consumesSubstrate :HydrogenIon ,
                              :Polyphosphate ,
                              :VolatileFattyAcids ;
           :occursIn :AnaerobicBioreactor ;
           :producesProduct :Calcium ,
                            :Magnesium ,
                            :Phosphate ,
                            :Polyhydroxyalkanoate ,
                            :Potassium ;
           :isDefinedBy "Release of phosphate from intracellular polyphosphate during anaerobic uptake and storage of volatile fatty acids by phosphate-accumulating organisms." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Phosphate
:Phosphate rdf:type owl:NamedIndividual ,
                    :Soluble ;
           :GujerNotation "PO43-" ,
                          "S_PO4" ;
           rdfs:isDefinedBy "A dissolved inorganic phosphorus component present in wastewater treatment systems, primarily in the form of phosphate ions. Phosphate serves as an essential nutrient for microbial growth and metabolism and plays a central role in biological and chemical phosphorus removal, nutrient cycling, mineral precipitation, eutrophication control, and resource recovery processes within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Polyhydroxyalkanoate
:Polyhydroxyalkanoate rdf:type owl:NamedIndividual ,
                               :Particulate ;
                      :EmpiricalFormula "C4H6O2" ;
                      :GujerNotation "X_PAO_Stor" ;
                      rdfs:isDefinedBy "A cellular storage polymer produced and accumulated by certain microorganisms in wastewater treatment systems as an internal carbon and energy reserve. Polyhydroxyalkanoate plays an important role in microbial metabolism and enhanced biological phosphorus removal processes, particularly in phosphate-accumulating organisms, where it is synthesised under anaerobic conditions and later utilised for growth, phosphorus uptake, and energy generation under aerobic or anoxic conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Polyphosphate
:Polyphosphate rdf:type owl:NamedIndividual ,
                        :Particulate ;
               :EmpiricalFormula "KkpMgmpCacpPO3" ;
               :GujerNotation "X_PAO_PP" ;
               rdfs:isDefinedBy "A cellular phosphorus storage polymer accumulated by certain microorganisms in wastewater treatment systems, particularly phosphate-accumulating organisms. Polyphosphate functions as an intracellular phosphorus and energy reserve and plays a central role in enhanced biological phosphorus removal processes, where microorganisms alternately release and uptake phosphorus under anaerobic and aerobic or anoxic conditions, contributing to nutrient removal and phosphorus recovery." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Potassium
:Potassium rdf:type owl:NamedIndividual ,
                    :Soluble ;
           :EmpiricalFormula "K+" ;
           :GujerNotation "S_K" ;
           rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and saline wastewaters. Potassium serves as an essential nutrient for microbial growth and cellular function and participates in osmotic regulation, ionic balance, biological phosphorus removal, mineral precipitation, and nutrient recovery processes within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PrecipitationOfCa3PO42
:PrecipitationOfCa3PO42 rdf:type owl:NamedIndividual ,
                                 :PhosphorusRemovalProcess ;
                        :consumesSubstrate :Calcium ,
                                           :Phosphate ;
                        :occursIn :AnaerobicBioreactor ;
                        :producesProduct :CalciumPhosphate ;
                        :isDefinedBy "Chemical precipitation of calcium phosphate during phosphorus removal and mineral formation processes in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PrecipitationOfMgNH4PO4
:PrecipitationOfMgNH4PO4 rdf:type owl:NamedIndividual ,
                                  :PhosphorusRemovalProcess ;
                         :consumesSubstrate :Ammonium ,
                                            :Magnesium ,
                                            :Phosphate ;
                         :occursIn :AnaerobicBioreactor ;
                         :producesProduct :Struvite ;
                         :isDefinedBy "Chemical precipitation of magnesium ammonium phosphate (struvite) during phosphorus and nutrient recovery processes in wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#PrimarySludgeBiodegradableParticulateOrganics
:PrimarySludgeBiodegradableParticulateOrganics rdf:type owl:NamedIndividual ,
                                                        :Particulate ;
                                               :EmpiricalFormula "CHYbpsOZbpsNAbpsPBbps" ;
                                               :GujerNotation "X_B_Inf" ;
                                               rdfs:isDefinedBy "A particulate biodegradable organic component originating from primary sludge in wastewater treatment systems. This component consists of settleable organic solids that can undergo biological degradation through processes such as hydrolysis, fermentation, anaerobic digestion, and aerobic decomposition, contributing to carbon transformation, biomass growth, sludge stabilisation, and biogas production within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Propionate
:Propionate rdf:type owl:NamedIndividual ,
                     :Soluble ;
            :GujerNotation "CH3CH2COO-" ,
                           "S_Pr" ;
            rdfs:isDefinedBy "A soluble volatile fatty acid component produced during the fermentation and degradation of organic matter in wastewater treatment systems. Propionate serves as an intermediate substrate in anaerobic digestion and carbon transformation processes and is utilised by microorganisms during acetogenesis, sulfate reduction, and methanogenesis, thereby contributing to microbial metabolism, biogas production, and nutrient cycling within wastewater treatment systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Sodium
:Sodium rdf:type owl:NamedIndividual ,
                 :Soluble ;
        :EmpiricalFormula "Na+" ;
        :GujerNotation "S_Na" ;
        rdfs:isDefinedBy "A dissolved inorganic cation component commonly present in wastewater treatment systems and saline wastewaters. Sodium contributes to salinity, osmotic balance, ionic strength, conductivity, and microbial stress conditions, and may influence microbial activity, process kinetics, sludge characteristics, and the overall performance of biological and physicochemical wastewater treatment processes under saline conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#StorageOfGlycogen
:StorageOfGlycogen rdf:type owl:NamedIndividual ,
                            :PhosphorusRemovalProcess ;
                   :consumesSubstrate :DissolvedOxygen ,
                                      :Glucose ,
                                      :HydrogenIon ,
                                      :Polyhydroxyalkanoate ;
                   :occursIn :AnaerobicBioreactor ;
                   :producesProduct :Carbonate ,
                                    :Glycogen ,
                                    :HydrogenIon ;
                   :isDefinedBy "Storage of glycogen through conversion of soluble sugar equivalents into intracellular glycogen during biological phosphorus removal." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#StorageOfPHAByXpa
:StorageOfPHAByXpa rdf:type owl:NamedIndividual ,
                            :PhosphorusRemovalProcess ;
                   :consumesSubstrate :HydrogenIon ,
                                      :Polyphosphate ,
                                      :VolatileFattyAcids ,
                                      :Water ;
                   :occursIn :AnaerobicBioreactor ;
                   :producesProduct :Calcium ,
                                    :Carbonate ,
                                    :HydrogenIon ,
                                    :Magnesium ,
                                    :Phosphate ,
                                    :Polyhydroxyalkanoate ,
                                    :Potassium ;
                   :usesElectronDonor :VolatileFattyAcids ;
                   :isDefinedBy "Storage of polyhydroxyalkanoate by Xpa through uptake of volatile fatty acids and conversion into intracellular storage polymer under anaerobic conditions." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Struvite
:Struvite rdf:type owl:NamedIndividual ,
                   :Particulate ;
          :EmpiricalFormula "MgNH4PO4.6H2O" ;
          :GujerNotation "X_Str_NH4" ;
          rdfs:isDefinedBy "A mineral phosphate component composed primarily of magnesium, ammonium, and phosphate that forms through precipitation processes in wastewater treatment systems under suitable chemical and environmental conditions. Struvite plays an important role in phosphorus and nitrogen recovery, nutrient removal, mineral scaling, sludge treatment, and resource recovery processes within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Sulfite
:Sulfite rdf:type owl:NamedIndividual ,
                  :Soluble ;
         :EmpiricalFormula "SO3^2-" ;
         :GujerNotation "S_SO3" ;
         rdfs:isDefinedBy "Sulfite is a soluble inorganic sulfur oxyanion that may occur as an intermediate in biological sulfur cycling. In wastewater treatment systems, sulfite can be reduced or oxidised during anaerobic and sulfur-based microbial processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Sulphate
:Sulphate rdf:type owl:NamedIndividual ,
                   :Soluble ;
          :EmpiricalFormula "SO42-" ;
          :GujerNotation "S_SO4" ;
          rdfs:isDefinedBy "A dissolved inorganic sulfur component commonly present in wastewater treatment systems and saline wastewaters. Sulphate serves as an alternative electron acceptor for sulfate-reducing microorganisms under anaerobic conditions and plays an important role in sulfur cycling, sulfide production, autotrophic denitrification, salinity effects, corrosion processes, odor generation, and nutrient transformations within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Thiosulfate
:Thiosulfate rdf:type owl:NamedIndividual ,
                      :Soluble ;
             :EmpiricalFormula "S2O3^2-" ;
             :GujerNotation "S_S2O3" ;
             rdfs:isDefinedBy "Thiosulfate is a soluble inorganic sulfur oxyanion containing sulfur in mixed oxidation states. It is relevant in wastewater treatment because it can act as an intermediate or reducible sulfur compound in anaerobic sulfur transformations." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UnbiodegradableParticulateOrganics
:UnbiodegradableParticulateOrganics rdf:type owl:NamedIndividual ,
                                             :Particulate ;
                                    :EmpiricalFormula "X_U_inf" ;
                                    :GujerNotation "CHYupOZupNAupPBup" ;
                                    rdfs:isDefinedBy "A particulate organic component consisting of suspended organic matter that cannot be readily degraded or biologically transformed by microorganisms within wastewater treatment systems. Unbiodegradable particulate organics contribute to inert solids accumulation, sludge production, suspended solids concentration, and solids handling processes, and may persist throughout biological treatment and sludge processing operations." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UnbiodegradableSolubleOrganics
:UnbiodegradableSolubleOrganics rdf:type owl:NamedIndividual ,
                                         :Soluble ;
                                :EmpiricalFormula "CHYuOZuNAuPBu" ,
                                                  "S_U" ;
                                rdfs:isDefinedBy "A soluble organic component consisting of dissolved organic matter that cannot be readily degraded or biologically transformed by microorganisms within wastewater treatment systems. Unbiodegradable soluble organics persist in the liquid phase throughout treatment processes and contribute to residual chemical oxygen demand, effluent organic content, and the accumulation of refractory organic compounds within wastewater treatment and resource recovery systems." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UptakeOfAcetateInADM
:UptakeOfAcetateInADM rdf:type owl:NamedIndividual ,
                               :CarbonRemovalProcess ;
                      :consumesSubstrate :Acetate ,
                                         :Ammonium ,
                                         :Carbonate ,
                                         :HydrogenIon ,
                                         :Phosphate ;
                      :hasKineticParameter :DecayRate_AM ,
                                           :MaxGrowthRate_AM ;
                      :occursIn :AnaerobicBioreactor ;
                      :producesProduct :AM_Biomass ,
                                       :Ammonium ,
                                       :Carbonate ,
                                       :Methane ,
                                       :Phosphate ,
                                       :Sulphate ;
                      :usesElectronDonor :Acetate ;
                      :isDefinedBy "Anaerobic uptake and conversion of acetate by acetoclastic methanogens resulting in methane production and methanogenic biomass growth during anaerobic digestion." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UptakeOfHydrogenInADM
:UptakeOfHydrogenInADM rdf:type owl:NamedIndividual ,
                                :CarbonRemovalProcess ;
                       :consumesSubstrate :Ammonium ,
                                          :Carbonate ,
                                          :Hydrogen ,
                                          :HydrogenIon ,
                                          :Phosphate ;
                       :hasKineticParameter :DecayRate_HM ,
                                            :MaxGrowthRate_HM ;
                       :occursIn :AnaerobicBioreactor ;
                       :producesProduct :HM_Biomass ,
                                        :Methane ,
                                        :Sulphate ;
                       :usesElectronAcceptor :CarbonDioxide ;
                       :usesElectronDonor :Hydrogen ;
                       :isDefinedBy "Anaerobic uptake and conversion of hydrogen by hydrogenotrophic methanogens resulting in methane production and methanogenic biomass growth during anaerobic digestion." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UptakeOfProprionateInADM
:UptakeOfProprionateInADM rdf:type owl:NamedIndividual ,
                                   :CarbonRemovalProcess ;
                          :consumesSubstrate :HydrogenIon ;
                          :hasKineticParameter :DecayRate_AC ,
                                               :MaxGrowthRate_AC ;
                          :occursIn :AnaerobicBioreactor ;
                          :producesProduct :AC_Biomass ,
                                           :Ammonium ,
                                           :Carbonate ,
                                           :Hydrogen ,
                                           :Phosphate ,
                                           :Sulphate ,
                                           :VolatileFattyAcids ;
                          :isDefinedBy "Anaerobic uptake and degradation of proprionate by acetogenic microorganisms resulting in the production of acetate, hydrogen, and acetogenic biomass during anaerobic digestion processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#UptakeOfSugarsInADM
:UptakeOfSugarsInADM rdf:type owl:NamedIndividual ,
                              :CarbonRemovalProcess ;
                     :consumesSubstrate :Glucose ,
                                        :HydrogenIon ;
                     :hasKineticParameter :DecayRate_AD ,
                                          :MaxGrowthRate_AD ;
                     :occursIn :AnaerobicBioreactor ;
                     :producesProduct :Ammonium ,
                                      :Carbonate ,
                                      :Hydrogen ,
                                      :HydrogenSulfide ,
                                      :Phosphate ,
                                      :Sulphate ,
                                      :VolatileFattyAcids ;
                     :usesElectronDonor :Glucose ;
                     :isDefinedBy "Anaerobic uptake and degradation of sugars by acidogenic microorganisms resulting in the production of volatile fatty acids, hydrogen, and acidogenic biomass during anaerobic digestion processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#VolatileFattyAcids
:VolatileFattyAcids rdf:type owl:NamedIndividual ,
                             :Soluble ;
                    :GujerNotation "S_VFA" ;
                    rdfs:isDefinedBy "A soluble organic component consisting of volatile fatty acids produced during the fermentation and anaerobic degradation of organic matter in wastewater treatment systems. VFAs serve as important intermediate substrates and carbon sources for microorganisms involved in processes such as denitrification, sulfate reduction, enhanced biological phosphorus removal, acetogenesis, and methanogenesis, thereby contributing to carbon transformation, nutrient removal, and anaerobic digestion processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#Water
:Water rdf:type owl:NamedIndividual ,
                :Soluble ;
       :EmpiricalFormula "H2O" ;
       :GujerNotation "H2O" ;
       rdfs:isDefinedBy "A soluble organic component consisting of volatile fatty acids produced during the fermentation and anaerobic degradation of organic matter in wastewater treatment systems. VFAs serve as important intermediate substrates and carbon sources for microorganisms involved in processes such as denitrification, sulfate reduction, enhanced biological phosphorus removal, acetogenesis, and methanogenesis, thereby contributing to carbon transformation, nutrient removal, and anaerobic digestion processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#XacEndogenousDecay
:XacEndogenousDecay rdf:type owl:NamedIndividual ,
                             :CarbonRemovalProcess ;
                    :consumesSubstrate :AC_Biomass ,
                                       :HydrogenIon ;
                    :hasKineticParameter :DecayRate_AC ;
                    :occursIn :AnaerobicBioreactor ;
                    :producesProduct :Ammonium ,
                                     :BiodegradableParticulateOrganics ,
                                     :Carbonate ,
                                     :EndogenousResidue ,
                                     :Phosphate ,
                                     :UnbiodegradableParticulateOrganics ;
                    :isDefinedBy "Endogenous decay and lysis of acetogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#XamEndogenousDecay
:XamEndogenousDecay rdf:type owl:NamedIndividual ,
                             :CarbonRemovalProcess ;
                    :consumesSubstrate :AM_Biomass ,
                                       :HydrogenIon ;
                    :hasKineticParameter :DecayRate_AM ;
                    :occursIn :AnaerobicBioreactor ;
                    :producesProduct :Ammonium ,
                                     :BiodegradableParticulateOrganics ,
                                     :Carbonate ,
                                     :EndogenousResidue ,
                                     :Phosphate ,
                                     :UnbiodegradableParticulateOrganics ;
                    :isDefinedBy "Endogenous decay and lysis of acetoclastic methanogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." .


###  http://www.semanticweb.org/hope/ontologies/2026/3/WRRFs_Ontology2#XhmEndogenousDecay
:XhmEndogenousDecay rdf:type owl:NamedIndividual ,
                             :CarbonRemovalProcess ;
                    :consumesSubstrate :HM_Biomass ,
                                       :HydrogenIon ;
                    :hasKineticParameter :DecayRate_HM ;
                    :occursIn :AnaerobicBioreactor ;
                    :producesProduct :Ammonium ,
                                     :BiodegradableParticulateOrganics ,
                                     :Carbonate ,
                                     :EndogenousResidue ,
                                     :Phosphate ,
                                     :UnbiodegradableParticulateOrganics ;
                    :isDefinedBy "Endogenous decay and lysis of hydrogenotrophic methanogenic biomass resulting in the formation of biodegradable particulate organics, inorganic nutrients, and endogenous residue during anaerobic wastewater treatment processes." .


